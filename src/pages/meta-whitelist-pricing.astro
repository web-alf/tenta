---
import BaseLayout from '@layouts/BaseLayout.astro';
import LpHero from '@components/sections/lp/LpHero.astro';
import LpWhyPlatform from '@components/sections/lp/LpWhyPlatform.astro';
import LpComparison from '@components/sections/lp/LpComparison.astro';
import LpPhotoVisit from '@components/sections/lp/LpPhotoVisit.astro';
import IndustriesGrid from '@components/sections/IndustriesGrid.astro';
import LpTestimonials from '@components/sections/lp/LpTestimonials.astro';
import PricingSection from '@components/sections/service/PricingSection.astro';
import LpShortForm from '@components/sections/lp/LpShortForm.astro';
import ArrowRight from '@components/icons/ArrowRight.astro';

import { META_LP, INDUSTRIES_LP, INDUSTRY_LP_HEADING } from '@data/whitelist-lp';
import { SEWA_PLANS } from '@data/sewa-akun';
import { serviceJsonLd, breadcrumbJsonLd } from '@lib/seo';
import { site } from '@data/site';
import { getLang, useT } from '@i18n/utils';

const lang = getLang(Astro.currentLocale);
const t = useT(lang);
const d = META_LP[lang];
const path = lang === 'en' ? '/en/meta-whitelist-pricing' : '/meta-whitelist-pricing';
const url = `${site.url}${path}`;

const englishPlans: typeof SEWA_PLANS = [
  {
    name: 'Starter', tagline: 'Minimum spending $20',
    price: '5%', unit: 'top-up fee',
    features: ['$20 - $300 per top-up', 'Official Whitelist Account', 'No VAT fees', 'Partner-level appeal support', 'Auto-balance transfer if disabled (T&C apply)', 'Priority support (Standard)'],
  },
  {
    name: 'Growth', tagline: 'Minimum spending $20',
    price: '4.5%', unit: 'top-up fee', featured: true,
    features: ['$300 - $900 per top-up', 'Official Whitelist Account', 'No VAT fees', 'Partner-level appeal support', 'Auto-balance transfer if disabled (T&C apply)', 'Priority support (Priority)'],
  },
  {
    name: 'Scale', tagline: 'Minimum spending $20',
    price: '3.5%', unit: 'top-up fee',
    features: ['Above $900 per top-up', 'Official Whitelist Account', 'No VAT fees', 'Partner-level appeal support', 'Auto-balance transfer if disabled (T&C apply)', 'Priority support (VIP)'],
  },
];

const plans = lang === 'en' ? englishPlans : SEWA_PLANS;

const jsonLd = [
  serviceJsonLd({ name: d.seo.title, description: d.seo.description, url, serviceType: 'Meta Ads Whitelist' }),
  breadcrumbJsonLd([
    { name: lang === 'en' ? 'Home' : 'Beranda', url: lang === 'en' ? `${site.url}/en` : site.url },
    { name: lang === 'en' ? 'Account Rental' : 'Sewa Akun', url: `${site.url}${lang === 'en' ? '/en' : ''}/layanan/sewa-akun` },
    { name: 'Meta Whitelist Pricing', url },
  ]),
];

const waText = lang === 'en' 
  ? "Hi Tentaklik! I'm interested in the Meta Whitelist Account Rental service. Could you share more details?"
  : "Halo Tentaklik! Saya tertarik dengan layanan Sewa Akun Meta Whitelist. Bisa minta info lebih lanjut?";
const waUrl = `https://wa.me/6285129992225?text=${encodeURIComponent(waText)}`;
---
<BaseLayout
  title={`${d.seo.title} — Pricing`}
  description={d.seo.description}
  active="layanan"
  jsonLd={jsonLd}
  keywords={d.keywords}
  bareHeader={true}
  bareLayout={true}
  preloadHeroSrc="true"
>
  <Fragment slot="head">
    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1341980327384883');
      fbq('track', 'PageView');
    </script>
    <!-- End Meta Pixel Code -->
  </Fragment>

  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1341980327384883&ev=PageView&noscript=1"
  /></noscript>

  <LpHero
    eyebrow={d.hero.eyebrow}
    title={d.hero.title}
    titleAccent={d.hero.titleAccent}
    desc={d.hero.desc}
    ctaText={lang === 'en' ? 'See Pricing' : 'Lihat Harga'}
    ctaHref="#pricing"
  />
  
  <LpWhyPlatform 
    platform={d.platform} 
    heading={d.whyHeading} 
    sub={d.whySub} 
    items={d.whyItems} 
  />
  
  <LpComparison platform={d.platform} />
  
  <LpPhotoVisit 
    heading={d.photoHeading} 
    sub={d.photoSub} 
    photos={d.photos} 
    variant="meta" 
  />

  <PricingSection plans={plans} service="Meta Ads Whitelist" />

  <IndustriesGrid 
    items={INDUSTRIES_LP[lang]} 
    heading={INDUSTRY_LP_HEADING[lang]} 
    bg="warm" 
    center 
    variant="premium"
  />

  <LpTestimonials />

  <LpShortForm platform="meta" hasPricing={true} />
</BaseLayout>
