---
import BaseLayout from '@layouts/BaseLayout.astro';
import WhitelistFullForm from '@components/sections/lp/WhitelistFullForm.astro';
import { site } from '@data/site';

const title = 'Form Google Ads Whitelist';
const description = 'Ajukan akun Google Ads Whitelist premium. Isi formulir lengkap, tim kami hubungi kamu via WhatsApp.';
const url = `${site.url}/form-google-whitelist`;
---
<BaseLayout
  title={title}
  description={description}
  active="layanan"
>
  <Fragment slot="head">
    <link rel="canonical" href={url} />
  </Fragment>

  <div style="padding-top:48px;padding-bottom:64px;">
    <WhitelistFullForm platform="google" />
  </div>
</BaseLayout>
