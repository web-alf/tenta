---
// LP Meta Whitelist — English, USD pricing for international market.
import BaseLayout from '@layouts/BaseLayout.astro';
import LpHero from '@components/sections/lp/LpHero.astro';
import LpWhyPlatform from '@components/sections/lp/LpWhyPlatform.astro';
import LpComparison from '@components/sections/lp/LpComparison.astro';
import LpPhotoVisit from '@components/sections/lp/LpPhotoVisit.astro';
import IndustriesGrid from '@components/sections/IndustriesGrid.astro';
import LpTestimonials from '@components/sections/lp/LpTestimonials.astro';
import LpPromoBanner from '@components/sections/lp/LpPromoBanner.astro';
import LpShortForm from '@components/sections/lp/LpShortForm.astro';
import PricingSection from '@components/sections/service/PricingSection.astro';
import { META_LP, INDUSTRIES_LP, INDUSTRY_LP_HEADING } from '@data/whitelist-lp';
import { serviceJsonLd, breadcrumbJsonLd } from '@lib/seo';
import { site } from '@data/site';

const d = META_LP.en;
const url = `${site.url}/meta-whitelist-usd`;
const jsonLd = [
  serviceJsonLd({ name: d.seo.title, description: d.seo.description, url, serviceType: 'Meta Ads Whitelist Account Rental' }),
  breadcrumbJsonLd([
    { name: 'Home', url: site.url },
    { name: 'Account Rental', url: `${site.url}/layanan/sewa-akun` },
    { name: 'Meta Whitelist (USD)', url },
  ]),
];

// USD pricing tiers (same % fee, topup range converted from IDR).
const usdPlans = [
  {
    name: 'Starter', tagline: 'Minimum spending $20',
    price: '5%', unit: 'top-up fee',
    features: ['$20 - $300 per top-up', 'Official Meta Whitelist', 'No VAT fees', 'Partner-level appeal support', 'Auto-balance transfer if disabled (T&C apply)', 'Priority support (Standard)'],
  },
  {
    name: 'Growth', tagline: 'Minimum spending $20',
    price: '4.5%', unit: 'top-up fee', featured: true,
    features: ['$300 - $900 per top-up', 'Official Meta Whitelist', 'No VAT fees', 'Partner-level appeal support', 'Auto-balance transfer if disabled (T&C apply)', 'Priority support (Priority)'],
  },
  {
    name: 'Scale', tagline: 'Minimum spending $20',
    price: '3.5%', unit: 'top-up fee',
    features: ['Above $900 per top-up', 'Official Meta Whitelist', 'No VAT fees', 'Partner-level appeal support', 'Auto-balance transfer if disabled (T&C apply)', 'Priority support (VIP)'],
  },
];

// Testimonials are now fetched dynamically from data/whitelist-lp.ts
---
<BaseLayout
  lang="en"
  title="Meta Ads Whitelist Account Rental (USD) — Tentaklik"
  description="Rent a Meta Ads whitelist account for international advertisers. USD pricing, no VAT, no spending limit."
  active="layanan"
  bareLayout={true}
  bareHeader={true}
  preloadHeroSrc="/assets/kraken-hero.png"
  jsonLd={jsonLd}
  keywords={['meta ads whitelist usd', 'rent meta ads account', 'facebook ads whitelist international', 'facebook ads agency account', 'meta invoice account', 'no daily spending limit meta account']}
>
  <LpHero
    eyebrow={d.hero.eyebrow}
    title={d.hero.title}
    titleAccent={d.hero.titleAccent}
    desc={d.hero.desc}
    ctaText="See Pricing"
    ctaHref="#pricing"
  />
  <LpWhyPlatform 
    platform={d.platform} 
    heading={d.whyHeading} 
    sub={d.whySub} 
    items={d.whyItems} 
  />
  <LpComparison platform={d.platform} lang="en" />
  <IndustriesGrid items={INDUSTRIES_LP.en} heading={INDUSTRY_LP_HEADING.en} bg="warm" center variant="premium" />
  <LpPhotoVisit heading={d.photoHeading} sub={d.photoSub} photos={d.photos} />
  <PricingSection plans={usdPlans} service="Meta Ads Whitelist (USD)" lang="en" />
  <LpTestimonials title="What Our Clients Say" sub="Success stories from advertisers who scaled their ads drama-free." items={d.testimonials.map(t => ({ data: t }))} />
  <LpPromoBanner originalPrice="$12" promoPrice="$5 / account" />
  <LpShortForm platform="meta" lang="en" />
</BaseLayout>
