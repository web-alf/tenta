---
import BaseLayout from '@layouts/BaseLayout.astro';
import KarirBenefits from '@components/sections/karir/KarirBenefits.astro';
import KarirJobList from '@components/sections/karir/KarirJobList.astro';
import KarirProcess from '@components/sections/karir/KarirProcess.astro';
import KarirApplyForm from '@components/sections/karir/KarirApplyForm.astro';
import ArrowRight from '@components/icons/ArrowRight.astro';
import { jobPostingJsonLd, breadcrumbJsonLd } from '@lib/seo';
import { site } from '@data/site';
import { getCollection } from 'astro:content';

const jobs = await getCollection('jobs');
const url = `${site.url}/karir`;
const datePosted = new Date().toISOString().slice(0, 10);

const jsonLd = [
  breadcrumbJsonLd([
    { name: 'Beranda', url: site.url },
    { name: 'Karir', url },
  ]),
  ...jobs.map(j => jobPostingJsonLd({
    title: j.data.title,
    description: `${j.data.summary} Persyaratan: ${j.data.requirements.join('; ')}.`,
    employmentType: j.data.type,
    location: j.data.location,
    datePosted,
    level: j.data.level,
    skills: j.data.tags as unknown as string[],
    url: `${url}#${j.data.slug}`,
  })),
];
---
<BaseLayout
  title="Karir di Tentaklik — Lowongan Digital Marketing & Web Developer"
  description="Lowongan kerja di Tentaklik: Web Developer, Meta Ads Specialist, Google Ads Specialist, TikTok Ads, dan Customer Specialist. Gabung tim agensi digital marketing yang serius soal hasil."
  active="karir"
  jsonLd={jsonLd}
  keywords={['lowongan kerja tentaklik', 'karir digital marketing', 'lowongan web developer semarang', 'lowongan meta ads', 'lowongan google ads specialist', 'karir agensi digital']}
>
  <section style="padding-top:56px;padding-bottom:48px;background:var(--bg-warm);position:relative;overflow:hidden;">
    <div class="container" style="display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:center;">
      <div>
        <span class="eyebrow">Karir</span>
        <h1 style="font-size:48px;margin-top:18px;margin-bottom:18px;">
          Gabung jadi <span style="color:var(--orange-500);">tentakel</span> baru di Tentaklik.
        </h1>
        <p style="font-size:17px;color:var(--ink-500);max-width:540px;">
          Kami sedang berkembang dan butuh orang-orang yang serius soal craft. Tim kecil, dampak besar — kamu bukan sekadar resource, tapi partner yang ikut bentuk arah Tentaklik.
        </p>
        <div style="display:flex;gap:12px;margin-top:28px;flex-wrap:wrap;">
          <a href="#lowongan" class="btn btn-primary">Lihat Lowongan <ArrowRight size={14} /></a>
          <a href="#proses" class="btn btn-ghost">Cara Apply</a>
        </div>
      </div>
      <div class="kraken-float" style="width:100%;max-width:560px;margin:0 auto;filter:drop-shadow(0 24px 48px rgba(255,107,26,0.18));">
        <picture>
          <source
            type="image/avif"
            srcset="/assets/kraken-hero-400.avif 400w, /assets/kraken-hero-560.avif 560w, /assets/kraken-hero-800.avif 800w, /assets/kraken-hero.avif 1200w"
            sizes="(max-width: 760px) min(480px, 95vw), 560px"
          />
          <source
            type="image/webp"
            srcset="/assets/kraken-hero-400.webp 400w, /assets/kraken-hero-560.webp 560w, /assets/kraken-hero-800.webp 800w, /assets/kraken-hero.webp 1200w"
            sizes="(max-width: 760px) min(480px, 95vw), 560px"
          />
          <img
            src="/assets/kraken-hero.png"
            alt="Tentaklik kraken"
            width="1200"
            height="960"
            loading="lazy"
            decoding="async"
            style="width:100%;height:auto;display:block;"
          />
        </picture>
      </div>
    </div>
  </section>

  <KarirBenefits />
  <KarirJobList />
  <KarirProcess />
  <KarirApplyForm />

  <section style="padding-bottom:24px;">
    <div class="container">
      <div class="cta-banner reveal" style="background:var(--orange-500);">
        <div style="flex:1;position:relative;z-index:1;">
          <h3>Posisi yang kamu cari belum ada?</h3>
          <p style="margin-top:8px;font-size:15px;opacity:0.95;">Tetap kirim CV kamu — kalau cocok, kami simpan untuk peluang berikutnya.</p>
        </div>
        <a href="mailto:karir@tentaklik.com" class="btn btn-ghost">Kirim CV ke Kami <ArrowRight size={14} /></a>
      </div>
    </div>
  </section>
</BaseLayout>
