---
import '@styles/global.css';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import StickyWA from '@components/layout/StickyWA.astro';
import { site } from '@data/site';
import { organizationJsonLd, localBusinessJsonLd, websiteJsonLd } from '@lib/seo';
import { PUBLIC_GA_ID } from 'astro:env/client';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { getLang, stripLocale } from '@i18n/utils';

const gaId = PUBLIC_GA_ID;
const gscVerification = site.verification.google;

const propLang = Astro.props.lang as 'en' | 'id' | undefined;
const lang = propLang || getLang(Astro.currentLocale);
const basePath = stripLocale(Astro.url.pathname);
const hrefId = getAbsoluteLocaleUrl('id', basePath);
const hrefEn = getAbsoluteLocaleUrl('en', basePath);
const ogLocale = lang === 'en' ? 'en_US' : 'id_ID';
const ogLocaleAlt = lang === 'en' ? 'id_ID' : 'en_US';

interface Props {
  lang?: 'en' | 'id';
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  active?: 'beranda' | 'layanan' | 'case' | 'tentang' | 'karir' | 'snk' | 'faq' | 'kontak';
  preloadHeroSrc?: string;
  jsonLd?: Record<string, unknown>[];
  keywords?: string[];
  bareLayout?: boolean;
  bareHeader?: boolean;
  pageType?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = site.description,
  image = site.defaultOgImage,
  canonical,
  noindex = false,
  active = 'beranda',
  preloadHeroSrc,
  jsonLd = [],
  keywords,
  bareLayout = false,
  bareHeader = false,
  pageType = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const fullTitle = title.toLowerCase().includes('tentaklik') ? title : `${title} — Tentaklik`;
const url = new URL(Astro.url.pathname, site.url).toString();
const canonicalUrl = canonical ?? url;
const ogImage = image.startsWith('http') ? image : new URL(image, site.url).toString();

const orgLd = organizationJsonLd();
const localBusinessLd = localBusinessJsonLd();
const websiteLd = websiteJsonLd();
const allLd = [orgLd, localBusinessLd, websiteLd, ...jsonLd];

const metaKeywords = (keywords ?? site.keywords as unknown as string[]).join(', ');
const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const JSONLD_ESCAPE = new RegExp('[<>&\u2028\u2029]', 'g');
function safeJsonLd(value: unknown): string {
  return JSON.stringify(value).replace(JSONLD_ESCAPE, (ch) => '\\u' + ch.charCodeAt(0).toString(16).padStart(4, '0'));
}

const cspContent = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "form-action 'self' https://wa.me",
  `script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com https://cdn-cgi/`,
  "style-src 'self' 'unsafe-inline'",
  "font-src 'self' data:",
  `img-src 'self' data: blob: https://www.google-analytics.com https://*.google-analytics.com https://*.g.doubleclick.net https://*.google.com`,
  `connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://*.g.doubleclick.net https://script.google.com https://script.googleusercontent.com`,
  "manifest-src 'self'",
  "worker-src 'self'",
  "media-src 'self'",
  "upgrade-insecure-requests",
].join('; ');
---
<!DOCTYPE html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <meta http-equiv="Content-Security-Policy" content={cspContent} />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-T6YX6NJRTK"></script>
    <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-T6YX6NJRTK');
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={metaKeywords} />
    <meta name="author" content={site.legalName} />
    <meta name="publisher" content={site.legalName} />
    <meta name="copyright" content={site.legalName} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="bingbot" content={robotsContent} />
    <meta name="rating" content="general" />
    <meta name="language" content="Indonesian" />
    <meta name="distribution" content="global" />
    <meta name="revisit-after" content="7 days" />
    <meta name="format-detection" content="telephone=yes" />

    <meta name="theme-color" content="#FF6B1A" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#FF6B1A" media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content="#FF6B1A" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={site.name} />
    <meta name="application-name" content={site.name} />
    <meta name="mobile-web-app-capable" content="yes" />

    <meta name="geo.region" content="ID-JT" />
    <meta name="geo.placename" content={`${site.geo.addressLocality}, ${site.geo.addressRegion}`} />
    <meta name="geo.position" content={`${site.geo.latitude};${site.geo.longitude}`} />
    <meta name="ICBM" content={`${site.geo.latitude}, ${site.geo.longitude}`} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="id" href={hrefId} />
    <link rel="alternate" hreflang="en" href={hrefEn} />
    <link rel="alternate" hreflang="x-default" href={hrefId} />

    <meta property="og:type" content={pageType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${description}`} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    {pageType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {pageType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {pageType === 'article' && <meta property="article:publisher" content={site.social.facebook} />}
    {pageType === 'article' && <meta property="article:author" content={site.legalName} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitterHandle} />
    <meta name="twitter:creator" content={site.twitterHandle} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${site.name} — ${description}`} />
    <meta name="twitter:domain" content="tentaklik.com" />
    <meta name="twitter:url" content={canonicalUrl} />

    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.ico" color="#FF6B1A" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />

    {preloadHeroSrc && (
      <Fragment set:html={`<link rel="preload" as="image" imagesrcset="/assets/kraken-hero-400.avif 400w, /assets/kraken-hero-560.avif 560w, /assets/kraken-hero-800.avif 800w" imagesizes="(max-width: 760px) min(480px, 95vw), 560px" type="image/avif" fetchpriority="high" />`} />
    )}

    <link rel="dns-prefetch" href="https://wa.me" />

    {gaId && <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />}
    {gaId && <link rel="dns-prefetch" href="https://www.google-analytics.com" />}
    {gaId && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
    {gaId && (
      <script
        is:inline
        set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`}
      />
    )}

    <Fragment set:html={allLd.map(ld => `<script type="application/ld+json">${safeJsonLd(ld)}</script>`).join('\n')} />
  </head>
  <body>
    {!bareHeader && <Header active={active} />}
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    {!bareLayout && <StickyWA />}

    <script>
      import { initReveal } from '@lib/reveal';
      initReveal();
    </script>

    <script is:inline>
      // Centralized Zaraz event tracking via event delegation
      // 1. Klik link ke /kontak → begin_checkout
      // 2. Klik link ke wa.me → whatsapp_click
      // 3. Submit form di /kontak → generate_lead
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a');
        if (!link || !window.zaraz) return;
        try {
          var url = new URL(link.href, window.location.origin);
          if (url.pathname === '/kontak' || url.pathname === '/kontak/') {
            window.zaraz.track('begin_checkout');
          }
          if (url.hostname === 'wa.me') {
            window.zaraz.track('whatsapp_click');
          }
        } catch (err) {}
      });
      document.addEventListener('submit', function() {
        if (window.location.pathname.indexOf('/kontak') === 0 && window.zaraz) {
          window.zaraz.track('generate_lead');
        }
      });
    </script>
  </body>
</html>
