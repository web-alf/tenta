---
import BaseLayout from './BaseLayout.astro';
import ServiceHero from '@components/sections/service/ServiceHero.astro';
import FeaturesGrid from '@components/sections/service/FeaturesGrid.astro';
import PricingSection from '@components/sections/service/PricingSection.astro';
import ServiceProcess from '@components/sections/service/ServiceProcess.astro';
import ServiceFAQ from '@components/sections/service/ServiceFAQ.astro';
import ServiceCTA from '@components/sections/service/ServiceCTA.astro';
import { serviceJsonLd, faqJsonLd, breadcrumbJsonLd } from '@lib/seo';
import { site } from '@data/site';

interface Props {
  data: {
    title: string;
    titleAccent: string;
    eyebrow: string;
    desc: string;
    icon: 'web' | 'google' | 'meta' | 'konsul';
    features: { icon: string; title: string; desc: string }[];
    plans: { name: string; tagline: string; price: string; unit: string; featured?: boolean; features: string[] }[];
    process: { title: string; desc: string }[];
    faqs: { q: string; a: string }[];
    seo: { title: string; description: string };
  };
  slug: string;
}

const { data, slug } = Astro.props;

const serviceImages: Record<string, string> = {
  web:    '/assets/services/webdev.png',
  google: '/assets/services/google.png',
  meta:   '/assets/services/meta.png',
  konsul: '/assets/services/konsul.png',
};
const imgSrc = serviceImages[data.icon];

const url = `${site.url}/layanan/${slug}`;
const serviceKeywordMap: Record<string, string[]> = {
  'website':     ['jasa pembuatan website', 'jasa website semarang', 'web developer indonesia', 'jasa landing page', 'jasa company profile', 'jasa e-commerce'],
  'google-ads':  ['jasa google ads', 'google ads specialist', 'jasa iklan google', 'jasa search ads', 'performance max indonesia', 'jasa youtube ads'],
  'meta-ads':    ['jasa meta ads', 'jasa facebook ads', 'jasa instagram ads', 'meta ads specialist', 'jasa iklan facebook', 'jasa iklan instagram'],
  'konsultasi':  ['konsultasi digital marketing', 'audit digital marketing', 'konsultan marketing online', 'strategi marketing digital'],
};
const jsonLd = [
  serviceJsonLd({
    name: data.seo.title,
    description: data.seo.description,
    url,
    serviceType: data.eyebrow,
    plans: data.plans.map(p => ({ name: p.name, price: p.price })),
  }),
  faqJsonLd(data.faqs),
  breadcrumbJsonLd([
    { name: 'Beranda',    url: site.url },
    { name: 'Layanan',    url: `${site.url}/#layanan` },
    { name: data.eyebrow, url },
  ]),
];
---
<BaseLayout
  title={data.seo.title}
  description={data.seo.description}
  active="layanan"
  jsonLd={jsonLd}
  keywords={serviceKeywordMap[slug] ?? [data.eyebrow.toLowerCase()]}
>
  <ServiceHero
    eyebrow={data.eyebrow}
    title={data.title}
    titleAccent={data.titleAccent}
    desc={data.desc}
  >
    <!-- Ilustrasi per layanan dengan float animation (konsisten dengan beranda) -->
    <div slot="illustration" class="service-img-wrap">
      <picture>
        <source type="image/avif" srcset={imgSrc.replace('.png', '.avif')} />
        <source type="image/webp" srcset={imgSrc.replace('.png', '.webp')} />
        <img src={imgSrc} alt={data.eyebrow} class="service-hero-img" width="600" height="600" loading="eager" fetchpriority="high" decoding="async" />
      </picture>
    </div>
  </ServiceHero>
  <FeaturesGrid title="Apa yang Kami Bawa" sub="Hal-hal kecil yang bikin hasil beda." items={data.features} />
  <PricingSection plans={data.plans} service={data.eyebrow} />
  <ServiceProcess steps={data.process} />
  <ServiceFAQ items={data.faqs} />
  <ServiceCTA />
</BaseLayout>

<style>
  .service-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    /* Float animation — sama dengan kraken-float di beranda */
    animation: krakenFloat 4.5s ease-in-out infinite;
    filter: drop-shadow(0 24px 48px rgba(255, 107, 26, 0.18));
    will-change: transform;
  }
  .service-hero-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
  }
  @keyframes krakenFloat {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    25%       { transform: translateY(-14px) rotate(0.8deg); }
    75%       { transform: translateY(-6px) rotate(-0.5deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .service-img-wrap { animation: none; }
  }
  @media (max-width: 760px) {
    .service-hero-img { max-width: min(340px, 85vw); }
  }
</style>
