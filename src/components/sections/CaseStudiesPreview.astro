---
import { getCollection } from 'astro:content';

const allCases = await getCollection('caseStudies');
const cases = allCases
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---
<section style="background:var(--bg-warm);">
  <div class="container">
    <h2 class="section-title">Partner Pilihan</h2>
    <p class="section-sub" style="margin-bottom:40px;">Brand &amp; partner yang sudah tumbuh bareng kami.</p>
    <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:20px;">
      {cases.map(c => (
        <div class="card reveal cs-card" style="display:flex;flex-direction:column;gap:14px;padding:0;overflow:hidden;">
          <!-- Cover image -->
          <div class="cs-cover">
            {c.data.cover ? (
              <picture>
                <source type="image/avif" srcset={c.data.cover.replace('.png', '.avif')} />
                <source type="image/webp" srcset={c.data.cover.replace('.png', '.webp')} />
                <img src={c.data.cover} alt={c.data.brand} loading="lazy" decoding="async" width="800" height="450" style="width:100%;height:100%;object-fit:cover;display:block;" />
              </picture>
            ) : (
              <div style="width:100%;height:100%;background:repeating-linear-gradient(135deg, var(--orange-100), var(--orange-100) 8px, var(--orange-50) 8px, var(--orange-50) 16px);display:flex;align-items:center;justify-content:center;border-bottom:1px dashed var(--orange-300);">
                <span style="font-family:'Inter Variable', 'Inter',sans-serif;font-size:12px;color:var(--orange-700);">{c.data.brand}</span>
              </div>
            )}
          </div>
          <!-- Content -->
          <div style="padding:18px 20px 20px;display:flex;flex-direction:column;gap:10px;flex:1;">
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
              {c.data.tags.map(t => <span style="font-size:11px;padding:4px 10px;background:var(--orange-100);color:var(--orange-700);border-radius:999px;font-weight:600;">{t}</span>)}
            </div>
            <h3 style="font-size:18px;margin:0;">{c.data.brand}</h3>
            <div style="font-size:22px;font-weight:800;color:var(--orange-600);font-family:'Plus Jakarta Sans Variable', 'Plus Jakarta Sans',sans-serif;">{c.data.metric}</div>
            <p style="font-size:14px;color:var(--ink-500);margin:0;line-height:1.6;">{c.data.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cs-cover {
    width: 100%;
    height: 180px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--orange-50);
  }
  .cs-cover :global(picture) { display: block; width: 100%; height: 100%; }
  .cs-cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
