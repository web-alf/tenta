---
import { getLang, useT } from '@i18n/utils';
const lang = getLang(Astro.currentLocale);
const t = useT(lang);

const steps = [
  { n: '01', icon: '🔍', title: t('proc.1.t'), desc: t('proc.1.d') },
  { n: '02', icon: '📋', title: t('proc.2.t'), desc: t('proc.2.d') },
  { n: '03', icon: '🚀', title: t('proc.3.t'), desc: t('proc.3.d') },
  { n: '04', icon: '📊', title: t('proc.4.t'), desc: t('proc.4.d') },
];
---
<section style="background:var(--bg-warm);">
  <div class="container">
    <h2 class="section-title">{t('proc.title')}</h2>
    <p class="section-sub" style="margin-bottom:40px;">{t('proc.sub')}</p>
    <div style="display:grid;grid-template-columns:repeat(4, 1fr);gap:16px;">
      {steps.map(s => (
        <div class="process-step reveal">
          <span class="process-num">{s.n}</span>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
            <h3 style="font-size:18px;">{s.title}</h3>
            <span style="font-size:18px;" aria-hidden="true">{s.icon}</span>
          </div>
          <p style="font-size:13px;color:var(--ink-500);">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
