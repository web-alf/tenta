---
import { getCollection } from 'astro:content';

const lang = Astro.currentLocale || 'id';
const isEn = lang === 'en';

const heading = isEn ? 'What Our Clients Say' : 'Kata Mereka yang Sudah Scale-Up';
const sub = isEn 
  ? 'Success stories from advertisers who scaled their ads drama-free.' 
  : 'Kisah sukses dari para advertiser yang berhasil scale-up tanpa drama banned.';

const allTesti = await getCollection('testimonials');
const items = allTesti.slice(0, 5);
---
<section style="background:var(--bg-warm); padding: 80px 0;">
  <div class="container" style="max-width:980px;">
    
    <div class="lp-testi-header">
      <div class="lp-testi-title-area">
        <h2 class="lp-testi-title">{heading}</h2>
        <p class="lp-testi-sub">{sub}</p>
      </div>
      <div class="lp-testi-nav">
        <button class="lp-testi-btn prev" aria-label="Slide sebelumnya">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
        </button>
        <button class="lp-testi-btn next" aria-label="Slide berikutnya">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>
    </div>

    <div class="lp-testi-carousel">
      <div class="lp-testi-track">
        {items.map((t) => (
          <div class="lp-testi-card">
            <div class="lp-testi-stars" aria-label={`${t.data.stars} bintang`}>
              {'★'.repeat(t.data.stars)}
            </div>
            <p class="lp-testi-text">"{t.data.text}"</p>
            <div class="lp-testi-author">
              <span class="lp-testi-avatar">
                {t.data.avatar ? (
                  <img src={t.data.avatar} class="lp-testi-avatar-img" alt={t.data.name} width="40" height="40" loading="lazy" />
                ) : (
                  t.data.initials
                )}
              </span>
              <div>
                <strong>{t.data.name}</strong>
                <span class="lp-testi-role">{t.data.role}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="lp-testi-dots">
      {items.map((_, idx) => (
        <button class={`lp-testi-dot ${idx === 0 ? 'active' : ''}`} data-index={idx} aria-label={`Ke slide ${idx + 1}`}></button>
      ))}
    </div>

  </div>
</section>

<script>
  const track = document.querySelector('.lp-testi-track') as HTMLElement;
  const prevBtn = document.querySelector('.lp-testi-btn.prev');
  const nextBtn = document.querySelector('.lp-testi-btn.next');
  const dots = document.querySelectorAll('.lp-testi-dot');

  if (track && prevBtn && nextBtn) {
    const getCardWidth = () => {
      const card = track.querySelector('.lp-testi-card');
      return card ? card.getBoundingClientRect().width + 16 : 300; // width + gap
    };

    const handleNext = () => {
      const maxScrollLeft = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft >= maxScrollLeft - 10) {
        track.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
      }
    };

    const handlePrev = () => {
      const maxScrollLeft = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft <= 10) {
        track.scrollTo({ left: maxScrollLeft, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
      }
    };

    // Auto-slide setup
    let autoSlideInterval = setInterval(handleNext, 5000);

    const resetAutoSlide = () => {
      clearInterval(autoSlideInterval);
      autoSlideInterval = setInterval(handleNext, 5000);
    };

    nextBtn.addEventListener('click', () => {
      handleNext();
      resetAutoSlide();
    });

    prevBtn.addEventListener('click', () => {
      handlePrev();
      resetAutoSlide();
    });

    // Reset timer on manual touch interaction (mobile/tablet)
    track.addEventListener('touchstart', resetAutoSlide, { passive: true });

    // Update active dot indicators on scroll
    track.addEventListener('scroll', () => {
      const scrollIndex = Math.round(track.scrollLeft / getCardWidth());
      dots.forEach((dot, idx) => {
        if (idx === scrollIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    }, { passive: true });
    
    // Dot navigation click handlers
    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        track.scrollTo({ left: idx * getCardWidth(), behavior: 'smooth' });
        resetAutoSlide();
      });
    });
  }
</script>

<style>
  :global(.lp-testi-header) {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 36px;
  }
  :global(.lp-testi-title-area) {
    max-width: 640px;
  }
  :global(.lp-testi-title) {
    font-size: 32px;
    font-weight: 800;
    color: var(--ink-900);
    margin: 0 0 10px 0;
    line-height: 1.25;
  }
  :global(.lp-testi-sub) {
    font-size: 16px;
    color: var(--ink-500);
    margin: 0;
    line-height: 1.5;
  }
  :global(.lp-testi-nav) {
    display: flex;
    gap: 8px;
    margin-bottom: 4px;
  }
  :global(.lp-testi-btn) {
    width: 44px;
    height: 44px;
    border-radius: 99px;
    border: 1.5px solid var(--orange-100);
    background: white;
    color: var(--orange-500);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  :global(.lp-testi-btn:hover) {
    background: var(--orange-50);
    border-color: var(--orange-400);
    color: var(--orange-600);
    transform: translateY(-1px);
  }
  :global(.lp-testi-btn:active) {
    transform: translateY(0);
  }

  :global(.lp-testi-carousel) {
    position: relative;
  }
  :global(.lp-testi-track) {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 8px 4px 20px 4px;
  }
  :global(.lp-testi-track::-webkit-scrollbar) {
    display: none;
  }

  :global(.lp-testi-card) {
    flex: 0 0 100%;
    scroll-snap-align: start;
    background: white;
    border: 1.5px solid var(--orange-100);
    border-radius: var(--radius-xl);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    box-sizing: border-box;
  }
  :global(.lp-testi-card:hover) {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--orange-400);
  }

  :global(.lp-testi-stars) { color: #FFB800; font-size: 16px; letter-spacing: 2px; }
  :global(.lp-testi-text) { font-size: 15px; color: var(--ink-700); line-height: 1.65; margin: 0; font-style: italic; }
  :global(.lp-testi-author) { display: flex; align-items: center; gap: 12px; margin-top: auto; }
  :global(.lp-testi-avatar) {
    width: 40px; height: 40px; border-radius: 999px;
    background: var(--orange-200); color: var(--orange-800);
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 15px; flex-shrink: 0;
    overflow: hidden;
  }
  :global(.lp-testi-avatar-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  :global(.lp-testi-author strong) { display: block; font-size: 14.5px; color: var(--ink-900); }
  :global(.lp-testi-role) { font-size: 12.5px; color: var(--ink-500); }

  :global(.lp-testi-dots) {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }
  :global(.lp-testi-dot) {
    width: 8px;
    height: 8px;
    border-radius: 99px;
    border: none;
    background: var(--ink-200);
    cursor: pointer;
    transition: all 0.25s ease;
    padding: 0;
  }
  :global(.lp-testi-dot.active) {
    background: var(--orange-500);
    width: 20px;
  }

  @media (min-width: 768px) {
    :global(.lp-testi-card) {
      flex: 0 0 calc((100% - 32px) / 3);
    }
  }

  @media (max-width: 680px) {
    :global(.lp-testi-header) {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    :global(.lp-testi-nav) {
      align-self: flex-end;
    }
    :global(.lp-testi-title) {
      font-size: 26px;
    }
    :global(.lp-testi-sub) {
      font-size: 14px;
    }
  }
</style>
