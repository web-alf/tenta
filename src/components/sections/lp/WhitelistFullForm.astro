---
import ArrowRight from '@components/icons/ArrowRight.astro';
import { getLang, useT } from '@i18n/utils';

interface Props {
  platform: 'meta' | 'google';
  lang?: 'en' | 'id';
}
const { platform } = Astro.props;
const lang = Astro.props.lang || getLang(Astro.currentLocale);
const t = useT(lang);
const formId = `wff-${platform}`;
const subKey = platform === 'google' ? 'mwf.sub.google' : 'mwf.sub';
---
<section aria-labelledby="wff-heading">
  <div class="container" style="max-width:620px;">
    <h2 id="wff-heading" class="section-title">{t('mwf.heading')}</h2>
    <p class="section-sub" style="margin-bottom:32px;">{t(subKey)}</p>
    <form
      id={formId}
      class="shortform wff"
      data-platform={platform}
      data-lang={lang}
      data-msg-sent={t('form.sent')}
      data-err-ktp={t('mwf.err.ktp')}
      data-err-ktp-size={t('mwf.err.ktp.size')}
      data-err-ktp-type={t('mwf.err.ktp.type')}
      data-err-sosmed={t('mwf.err.sosmed')}
      data-err-inactive={t('form.err.inactive')}
      novalidate
    >
      <input type="text" name="website_hp" tabindex="-1" autocomplete="off" class="sf-hp" aria-hidden="true" />

      <div class="sf-field">
        <label for={`${formId}-ktp`}>{t('mwf.ktp')} <span class="sf-req">*</span></label>
        <input id={`${formId}-ktp`} type="file" name="ktp" accept="image/jpeg,image/png,application/pdf" required />
        <span class="sf-help">{t('mwf.ktp.help')}</span>
      </div>

      {platform === 'google' && (
        <div class="sf-field">
          <label for={`${formId}-email`}>Email <span class="sf-req">*</span></label>
          <input id={`${formId}-email`} type="email" name="email" placeholder="contoh@email.com" required maxlength="150" />
        </div>
      )}

      <div class="sf-field">
        <label for={`${formId}-website`}>
          {t('mwf.website')} {platform === 'google' ? <span class="sf-req">*</span> : <span style="font-weight:normal;color:var(--ink-400)">(Opsional)</span>}
        </label>
        <input id={`${formId}-website`} type="url" name="website_url" placeholder={t('mwf.website.ph')} required={platform === 'google'} maxlength="200" />
      </div>

      <div class="sf-field">
        <label for={`${formId}-sosmed`}>
          {t('mwf.sosmed')} {platform === 'meta' ? <span class="sf-req">*</span> : <span style="font-weight:normal;color:var(--ink-400)">(Opsional)</span>}
        </label>
        <input id={`${formId}-sosmed`} type="text" name="sosmed" placeholder={t('mwf.sosmed.ph')} required={platform === 'meta'} maxlength="200" />
      </div>

      <button type="submit" class="btn btn-primary sf-submit" style="justify-content:center;width:100%;margin-top:8px;">
        <span class="sf-btn-label">{t('form.kirim')} <ArrowRight size={14} /></span>
        <span class="sf-btn-loading" aria-hidden="true"><span class="sf-spinner"></span> {t('form.mengirim')}</span>
      </button>
      <p class="sf-sent" role="status" aria-live="polite" hidden>{t('form.sent')}</p>
      <p class="sf-err" role="alert" aria-live="assertive" hidden></p>
    </form>
  </div>
</section>

<style>
  .shortform {
    background: white;
    border: 1.5px solid var(--orange-100);
    border-radius: var(--radius-xl);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .shortform:hover {
    border-color: var(--orange-300);
    box-shadow: var(--shadow-md);
  }
  .sf-hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .sf-field { display: flex; flex-direction: column; gap: 6px; }
  .sf-field label { font-size: 13px; font-weight: 600; color: var(--ink-700); }
  .sf-req { color: #b91c1c; }
  .sf-help { font-size: 12px; color: var(--ink-400); }
  .sf-field input, .sf-field textarea, .sf-field select {
    font: inherit; padding: 12px 14px;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--ink-100); background: white;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .sf-field input[type="file"] {
    padding: 10px 14px;
    cursor: pointer;
  }
  .sf-field input:focus, .sf-field textarea:focus, .sf-field select:focus {
    outline: none; border-color: var(--orange-500);
    box-shadow: 0 0 0 3px rgba(255,107,26,0.15);
  }
  .sf-sent { color: #15803d; font-size: 14px; font-weight: 600; margin: 0; }
  .sf-err { 
    background-color: #fef2f2;
    border: 1px solid #f87171;
    color: #b91c1c; 
    font-size: 13.5px; 
    line-height: 1.5;
    margin: 0; 
    padding: 12px 16px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .sf-submit { position: relative; }
  .sf-submit .sf-btn-label { display: inline-flex; align-items: center; gap: 8px; }
  .sf-submit .sf-btn-loading { display: none; align-items: center; gap: 8px; }
  .sf-submit.is-loading .sf-btn-label { display: none; }
  .sf-submit.is-loading .sf-btn-loading { display: inline-flex; }
  .sf-submit[disabled] { opacity: 0.85; cursor: progress; }
  .sf-spinner {
    width: 15px; height: 15px;
    border: 2px solid rgba(255,255,255,0.45);
    border-top-color: #fff;
    border-radius: 50%;
    display: inline-block;
    animation: sf-spin 0.6s linear infinite;
  }
  @keyframes sf-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .sf-spinner { animation-duration: 1.6s; }
  }
</style>

<script>
  // Webhook Google Apps Script untuk form lengkap (mendukung upload file KTP via POST)
  const SHORTFORM_URL = 'https://script.google.com/macros/s/AKfycbycrJWsxCxVH4BF9Ly6DadA6aAcjO2bgRj7rPXnmE_5Vy_8ZdlmJa7_PN4s8l2zfZeH/exec';
  const RAW_WA = import.meta.env.PUBLIC_WA_NUMBER ?? '6285129992225';
  const WA_NUMBER = String(RAW_WA).replace(/\D/g, '').slice(0, 15);

  const CTRL_RE = new RegExp('[\\u0000-\\u001F\\u007F]', 'g');
  const clip = (v: string, n: number) => v.replace(CTRL_RE, ' ').slice(0, n).trim();
  const MAX_FILE_SIZE = 5 * 1024 * 1024;
  const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'application/pdf'];
  const hasEndpoint = typeof SHORTFORM_URL === 'string' && SHORTFORM_URL.indexOf('http') === 0;

  // Fungsi kompresi gambar otomatis (Client-side)
  const compressImage = (file: File, maxWidth: number, maxHeight: number, quality: number): Promise<string> => {
    return new Promise((resolve, reject) => {
      if (!file.type.startsWith('image/')) {
        const reader = new FileReader();
        reader.onload = e => resolve((e.target?.result as string).split(',')[1]);
        reader.onerror = reject;
        reader.readAsDataURL(file);
        return;
      }

      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = (event) => {
        const img = new Image();
        img.src = event.target?.result as string;
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;

          if (width > height) {
            if (width > maxWidth) {
              height = Math.round((height * maxWidth) / width);
              width = maxWidth;
            }
          } else {
            if (height > maxHeight) {
              width = Math.round((width * maxHeight) / height);
              height = maxHeight;
            }
          }

          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          if (!ctx) {
            resolve((event.target?.result as string).split(',')[1]);
            return;
          }
          ctx.drawImage(img, 0, 0, width, height);
          const dataUrl = canvas.toDataURL('image/jpeg', quality);
          resolve(dataUrl.split(',')[1]);
        };
        img.onerror = error => reject(error);
      };
      reader.onerror = error => reject(error);
    });
  };

  document.querySelectorAll<HTMLFormElement>('form.wff').forEach((form) => {
    const sent = form.querySelector<HTMLElement>('.sf-sent');
    const err = form.querySelector<HTMLElement>('.sf-err');
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const platform = form.getAttribute('data-platform') ?? 'meta';
    const lang = form.getAttribute('data-lang') ?? 'id';

    const MSG = {
      ktp: form.getAttribute('data-err-ktp') ?? 'Foto KTP wajib diunggah.',
      ktpSize: form.getAttribute('data-err-ktp-size') ?? 'File KTP terlalu besar. Mohon unggah foto dengan ukuran maksimal 5 MB.',
      ktpType: form.getAttribute('data-err-ktp-type') ?? 'Format KTP tidak didukung. Harap gunakan format JPG, PNG, atau PDF.',
      sosmed: form.getAttribute('data-err-sosmed') ?? 'Akun sosial media wajib diisi.',
      inactive: form.getAttribute('data-err-inactive') ?? 'Sistem sedang dipelihara. Silakan coba lagi nanti.',
    };

    const showErr = (t: string) => {
      if (err) { 
        err.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top: 2px;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg> <span>${t}</span>`;
        err.hidden = false; 
        setTimeout(() => { if (err) err.hidden = true; }, 7000); 
      }
    };

    let busy = false;
    const setLoading = (on: boolean) => {
      busy = on;
      if (btn) { btn.disabled = on; btn.classList.toggle('is-loading', on); }
    };

    const layanan = platform === 'google' ? 'Google Ads Whitelist' : 'Meta Ads Whitelist';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (busy) return;
      if (sent) sent.hidden = true;

      const fd = new FormData(form);
      if (String(fd.get('website_hp') ?? '').length > 0) return;

      const email = clip(String(fd.get('email') ?? ''), 150);
      const sosmed = clip(String(fd.get('sosmed') ?? ''), 200);
      const websiteUrl = clip(String(fd.get('website_url') ?? ''), 200);

      const ktpInput = form.querySelector<HTMLInputElement>('input[name="ktp"]');
      const ktpFile = ktpInput?.files?.[0];
      if (!ktpFile) { showErr(MSG.ktp); return; }
      if (ktpFile.size > MAX_FILE_SIZE) { showErr(MSG.ktpSize); return; }
      if (!ALLOWED_TYPES.includes(ktpFile.type)) { showErr(MSG.ktpType); return; }

      if (platform === 'google') {
        if (!websiteUrl) { showErr("Website wajib diisi."); return; }
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showErr("Email tidak valid."); return; }
      }

      if (platform === 'meta' && !sosmed) {
        showErr(MSG.sosmed); return;
      }

      if (!hasEndpoint) { showErr(MSG.inactive); return; }

      setLoading(true);

      try {
        // Kompres gambar menjadi maksimal 1000px dengan kualitas 75%
        const base64Data = await compressImage(ktpFile, 1000, 1000, 0.75);
        
        const mimeType = ktpFile.type.startsWith('image/') ? 'image/jpeg' : ktpFile.type;
        const fileName = ktpFile.type.startsWith('image/') && !ktpFile.name.toLowerCase().endsWith('.jpg') && !ktpFile.name.toLowerCase().endsWith('.jpeg') 
                         ? ktpFile.name + '.jpg' 
                         : ktpFile.name;

        const payload = {
          platform,
          email,
          sosmed,
          website: websiteUrl,
          source: window.location.href.split('#')[0],
          fileData: base64Data,
          fileName: fileName,
          mimeType: mimeType
        };

        const greeting = lang === 'en'
          ? `Hello Tentaklik! I have submitted my documents (KTP) for the ${layanan} application.`
          : `Halo Tentaklik! Saya baru saja mengirimkan kelengkapan data (KTP) untuk pengajuan ${layanan}.`;

        const waUrl = WA_NUMBER
          ? `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(greeting)}`
          : '';

        if (typeof (window as any).fbq === 'function') {
          (window as any).fbq('track', 'Lead', {
            content_name: `${layanan} Document Form`,
          });
        }

        fetch(SHORTFORM_URL, { 
          method: 'POST',
          mode: 'no-cors',
          headers: {
            'Content-Type': 'text/plain'
          },
          body: JSON.stringify(payload)
        })
          .catch(() => {})
          .finally(() => {
            form.reset();
            if (sent) sent.hidden = false;
            setLoading(false);
            if (waUrl) {
              setTimeout(() => { window.location.href = waUrl; }, 800);
            }
          });
      } catch (err) {
        showErr("Gagal memproses file. Silakan coba lagi.");
        setLoading(false);
      }
    });
  });
</script>
