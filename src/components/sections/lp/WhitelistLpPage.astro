---
// Halaman LP whitelist (Meta/Google) — dipakai oleh route ID & EN.
// Tipis: pilih data per (platform, lang), render section yang sama.
import BaseLayout from '@layouts/BaseLayout.astro';
import LpHero from '@components/sections/lp/LpHero.astro';
import LpWhyPlatform from '@components/sections/lp/LpWhyPlatform.astro';
import LpComparison from '@components/sections/lp/LpComparison.astro';
import LpPhotoVisit from '@components/sections/lp/LpPhotoVisit.astro';
import IndustriesGrid from '@components/sections/IndustriesGrid.astro';
import LpTestimonials from '@components/sections/lp/LpTestimonials.astro';
import LpPromoBanner from '@components/sections/lp/LpPromoBanner.astro';
import LpShortForm from '@components/sections/lp/LpShortForm.astro';
import { META_LP, GOOGLE_LP, INDUSTRIES_LP, INDUSTRY_LP_HEADING } from '@data/whitelist-lp';
import { serviceJsonLd, breadcrumbJsonLd } from '@lib/seo';
import { site } from '@data/site';
import { getLang } from '@i18n/utils';

interface Props { platform: 'meta' | 'google' }
const { platform } = Astro.props;
const lang = getLang(Astro.currentLocale);

const d = (platform === 'google' ? GOOGLE_LP : META_LP)[lang];
const slug = platform === 'google' ? 'google-whitelist' : 'meta-whitelist';
const path = lang === 'en' ? `/en/${slug}` : `/${slug}`;
const url = `${site.url}${path}`;
const crumbWhitelist = platform === 'google' ? 'Google Whitelist' : 'Meta Whitelist';
const crumbSewa = lang === 'en' ? 'Account Rental' : 'Sewa Akun';
const crumbHome = lang === 'en' ? 'Home' : 'Beranda';

// Header is visible only for Google Whitelist, hidden for Meta
const hideHeader = platform !== 'google';

const jsonLd = [
  serviceJsonLd({
    name: d.seo.title,
    description: d.seo.description,
    url,
    serviceType: platform === 'google' ? 'Google Ads Whitelist Account Rental' : 'Meta Ads Whitelist Account Rental',
  }),
  breadcrumbJsonLd([
    { name: crumbHome, url: lang === 'en' ? `${site.url}/en` : site.url },
    { name: crumbSewa, url: `${site.url}${lang === 'en' ? '/en' : ''}/layanan/sewa-akun` },
    { name: crumbWhitelist, url },
  ]),
];
---
<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
  active="layanan"
  bareLayout
  bareHeader={hideHeader}
  jsonLd={jsonLd}
  keywords={d.keywords}
  preloadHeroSrc="true"
>
  {platform === 'meta' && (
    <Fragment slot="head">
      <!-- Meta Pixel Code -->
      <script is:inline>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '1341980327384883');
        fbq('track', 'PageView');
      </script>
      <!-- End Meta Pixel Code -->
    </Fragment>
  )}
  {platform === 'meta' && (
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=1341980327384883&ev=PageView&noscript=1"
    /></noscript>
  )}

  <LpHero
    eyebrow={d.hero.eyebrow}
    title={d.hero.title}
    titleAccent={d.hero.titleAccent}
    desc={d.hero.desc}
    ctaText={d.cta.btn}
    ctaHref={`#shortform-${platform}`}
  />
  <LpWhyPlatform 
    platform={d.platform} 
    heading={d.whyHeading} 
    sub={d.whySub} 
    items={d.whyItems} 
  />
  <LpComparison platform={d.platform} />
  <IndustriesGrid 
    items={INDUSTRIES_LP[lang]} 
    heading={INDUSTRY_LP_HEADING[lang]} 
    bg="warm" 
    center 
    variant="premium"
  />
  <LpPhotoVisit 
    heading={d.photoHeading} 
    sub={d.photoSub} 
    photos={d.photos} 
    variant={platform === 'google' ? 'grid' : 'meta'} 
  />
  <LpTestimonials items={d.testimonials.map(t => ({ data: t }))} />
  <LpPromoBanner />
  <LpShortForm platform={platform} />
</BaseLayout>
