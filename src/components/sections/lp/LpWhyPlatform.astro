---
import { Image } from 'astro:assets';
import ArrowRight from '@components/icons/ArrowRight.astro';
// Note: We use the generated 3D image here.
import meta3d from '@/assets/images/meta-whitelist-3d.png';
import google3d from '@/assets/images/google-whitelist-3d.png';

interface WhyItem {
  iconId: 'stable' | 'comfortable' | 'scale' | 'tax' | 'priority' | 'expert' | 'protection';
  title: string;
  desc: string;
}

interface Props {
  platform: 'meta' | 'google';
  heading: string;
  sub: string;
  items: WhyItem[];
}

const { platform, heading, sub, items } = Astro.props;

// For Meta layout, we expect exactly 7 items.
// We split them into left (indexes 0, 2, 4), right (indexes 1, 3, 5), and bottom (index 6).
const leftItems = items.slice(0, 6).filter((_, i) => i % 2 === 0);
const rightItems = items.slice(0, 6).filter((_, i) => i % 2 !== 0);
const bottomItem = items[6];

const centerImage = platform === 'meta' ? meta3d : google3d;
const imageAlt = platform === 'meta' ? 'Meta Whitelist 3D Illustration' : 'Google Whitelist 3D Illustration';
---
<section class="lp-why-section" id={`why-${platform}`} aria-labelledby="lp-why-heading">
  <div class="container">
    
    <!-- Centered Header -->
    <div class="why-header reveal">
      <h2 id="lp-why-heading" class="why-title" set:html={heading}></h2>
      <p class="why-sub" set:html={sub}></p>
    </div>

    <!-- Centerpiece Layout -->
    <div class="centerpiece-wrapper">
      
      <!-- Left Column -->
      <div class="side-col left-col">
        {leftItems.map((item, idx) => (
          <div class={`pill-card reveal delay-${idx}`}>
            <div class="icon-box">
              {item.iconId === 'stable' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              )}
              {item.iconId === 'scale' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.6-3.26a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                </svg>
              )}
              {item.iconId === 'priority' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
              )}
            </div>
            <div class="card-text">
              <h3 class="card-title">{item.title}</h3>
              <p class="card-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Center Image Column -->
      <div class="center-img-col reveal">
        <Image 
          src={centerImage} 
          alt={imageAlt} 
          class="centerpiece-img"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />
      </div>

      <!-- Right Column -->
      <div class="side-col right-col">
        {rightItems.map((item, idx) => (
          <div class={`pill-card reveal delay-${idx}`}>
            <div class="icon-box">
              {item.iconId === 'comfortable' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />
                </svg>
              )}
              {item.iconId === 'tax' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125H3.75a1.125 1.125 0 01-1.125-1.125V5.625c0-.621.504-1.125 1.125-1.125z" />
                </svg>
              )}
              {item.iconId === 'expert' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              )}
            </div>
            <div class="card-text">
              <h3 class="card-title">{item.title}</h3>
              <p class="card-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Bottom Item -->
    {bottomItem && (
      <div class="bottom-row reveal">
        <div class="pill-card pill-bottom">
          <div class="icon-box">
            {bottomItem.iconId === 'protection' && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            )}
          </div>
          <div class="card-text">
            <h3 class="card-title">{bottomItem.title}</h3>
            <p class="card-desc">{bottomItem.desc}</p>
          </div>
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .lp-why-section {
    padding-top: 100px;
    padding-bottom: 100px;
    background: #f8fafc; /* Very light cool grey matching the screenshot background */
    position: relative;
    overflow: hidden;
  }
  
  .why-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 60px auto;
  }
  
  .why-title {
    font-size: 42px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--ink-900);
    margin: 0 0 16px 0;
  }
  
  .text-orange {
    color: var(--orange-600);
  }
  
  .why-sub {
    font-size: 16.5px;
    line-height: 1.6;
    color: var(--ink-600);
    margin: 0;
  }

  /* Layout */
  .centerpiece-wrapper {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .side-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .left-col {
    align-items: flex-end; /* cards push towards center */
  }

  .right-col {
    align-items: flex-start; /* cards push towards center */
  }

  .center-img-col {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .centerpiece-img {
    width: 320px;
    max-width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.08));
    animation: float 6s ease-in-out infinite;
    mix-blend-mode: multiply;
    -webkit-mask-image: radial-gradient(circle at center, black 50%, transparent 75%);
    mask-image: radial-gradient(circle at center, black 50%, transparent 75%);
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }

  /* Pill Cards */
  .pill-card {
    background: white;
    border: 1.5px solid var(--orange-100);
    border-radius: 20px;
    padding: 16px 24px 16px 16px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    max-width: 320px;
    width: 100%;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s, border-color 0.3s;
  }

  .pill-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(255, 107, 26, 0.08);
    border-color: var(--orange-400);
  }

  .icon-box {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--orange-50);
    color: var(--orange-600);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-box svg {
    width: 22px;
    height: 22px;
  }

  .card-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--ink-900);
    margin: 0;
  }

  .card-desc {
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink-600);
    margin: 0;
  }

  /* Bottom Row */
  .bottom-row {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  .pill-bottom {
    max-width: 480px;
  }

  .mobile-only {
    display: none;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .centerpiece-wrapper {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .center-img-col {
      grid-row: 1; /* Move image to top */
    }
    
    .centerpiece-img {
      width: 280px;
    }

    .left-col, .right-col {
      align-items: center; /* Center everything on mobile */
    }

    .pill-card {
      max-width: 100%;
    }
    
    .bottom-row {
      margin-top: 24px;
    }
    
    .why-title {
      font-size: 36px;
    }
  }

  @media (max-width: 640px) {
    .lp-why-section {
      padding-top: 60px;
      padding-bottom: 60px;
    }
    
    .why-title {
      font-size: 30px;
    }

    .centerpiece-img {
      width: 240px;
    }

    .mobile-only {
      display: inline;
    }
  }
</style>
