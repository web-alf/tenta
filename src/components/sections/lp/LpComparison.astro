---
interface Props {
  platform: 'meta' | 'google';
  lang?: 'en' | 'id';
}

const { platform, lang = Astro.currentLocale === 'en' ? 'en' : 'id' } = Astro.props;
const isEn = lang === 'en';

const comparisons = [
  {
    leftIcon: 'user',
    leftText: isEn ? 'Suitable for general use' : 'Cocok untuk penggunaan umum',
    rightIcon: 'users',
    rightText: isEn ? 'Fit for active advertisers' : 'Cocok untuk bisnis yang aktif beriklan'
  },
  {
    leftIcon: 'settings',
    leftText: isEn ? 'Self-managed' : 'Dikelola secara mandiri',
    rightIcon: 'headset',
    rightText: isEn ? 'Gets support and guidance' : 'Mendapat dukungan dan pendampingan'
  },
  {
    leftIcon: 'chat',
    leftText: isEn ? 'Limited support' : 'Support terbatas',
    rightIcon: 'chat-orange',
    rightText: isEn ? 'Highly responsive support' : 'Dukungan yang lebih responsif'
  },
  {
    leftIcon: 'clipboard',
    leftText: isEn ? 'Fit for basic needs' : 'Cocok untuk kebutuhan dasar',
    rightIcon: 'chart',
    rightText: isEn ? 'Ready to scale up with your business' : 'Lebih siap mendukung kebutuhan bisnis yang berkembang'
  }
];
---
<section class="lp-comparison-section" id={`comparison-${platform}`}>
  <div class="container">
    
    <div class="comp-header reveal">
      <h2 class="comp-title">
        {isEn ? 'What is the Difference' : 'Apa Bedanya'} <span class="text-orange">{platform === 'meta' ? (isEn ? 'From Regular Accounts?' : 'Dengan Akun Biasa?') : (isEn ? 'From Regular Accounts?' : 'Dengan Akun Biasa?')}</span>
      </h2>
      <p class="comp-sub">{isEn ? 'Choose the solution that best fits your business needs.' : 'Pilih solusi yang paling sesuai untuk kebutuhan bisnis Anda.'}</p>
    </div>

    <!-- Dots Decor left -->
    <div class="dots-decor dots-left">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="2" cy="2" r="2" fill="#F97316"/>
        <circle cx="14" cy="2" r="2" fill="#F97316"/>
        <circle cx="26" cy="2" r="2" fill="#F97316"/>
        <circle cx="38" cy="2" r="2" fill="#F97316"/>
        <circle cx="2" cy="14" r="2" fill="#F97316"/>
        <circle cx="14" cy="14" r="2" fill="#F97316"/>
        <circle cx="26" cy="14" r="2" fill="#F97316"/>
        <circle cx="38" cy="14" r="2" fill="#F97316"/>
        <circle cx="2" cy="26" r="2" fill="#F97316"/>
        <circle cx="14" cy="26" r="2" fill="#F97316"/>
        <circle cx="26" cy="26" r="2" fill="#F97316"/>
        <circle cx="38" cy="26" r="2" fill="#F97316"/>
      </svg>
    </div>

    <div class="comp-table reveal">
      <!-- Header Row -->
      <div class="comp-row comp-header-row">
        <div class="comp-col comp-col-left header-col">
          <div class="header-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <h3>{isEn ? 'Regular Account' : 'Akun Biasa'}</h3>
        </div>
        
        <div class="comp-col comp-col-right header-col right-header-bg">
          <div class="header-icon-box orange-box">
             {platform === 'meta' ? (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 12c-2-2.67-4-4-6-4a4 4 0 1 0 0 8c2 0 4-1.33 6-4Zm0 0c2 2.67 4 4 6 4a4 4 0 1 0 0-8c-2 0-4 1.33-6 4Z"/>
                </svg>
             ) : (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                </svg>
             )}
          </div>
          <h3>{platform === 'meta' ? 'Meta Whitelist' : 'Google Whitelist'}</h3>
        </div>
      </div>

      <!-- Item Rows -->
      {comparisons.map((item, i) => (
        <div class="comp-row">
          <div class="comp-col comp-col-left">
            <div class="item-icon-box">
              {item.leftIcon === 'user' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
              )}
              {item.leftIcon === 'settings' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.107-1.204l-.527-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              )}
              {item.leftIcon === 'chat' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>
              )}
              {item.leftIcon === 'clipboard' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>
              )}
            </div>
            <p class="item-text">{item.leftText}</p>
          </div>
          
          <!-- VS Badge -->
          <div class="vs-badge">VS</div>

          <div class="comp-col comp-col-right">
            <div class="item-icon-box orange-text">
              {item.rightIcon === 'users' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
              )}
              {item.rightIcon === 'headset' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5A7.5 7.5 0 004.5 12v3a1.5 1.5 0 001.5 1.5h1.5A1.5 1.5 0 009 15v-3a1.5 1.5 0 00-1.5-1.5H6.1c.32-2.8 2.6-5 5.9-5s5.58 2.2 5.9 5h-1.4A1.5 1.5 0 0015 12v3a1.5 1.5 0 001.5 1.5h1.5a1.5 1.5 0 001.5-1.5v-3A7.5 7.5 0 0012 4.5z" /></svg>
              )}
              {item.rightIcon === 'chat-orange' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>
              )}
              {item.rightIcon === 'chart' && (
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
              )}
            </div>
            <p class="item-text">{item.rightText}</p>
          </div>
        </div>
      ))}
      
    </div>
    
    <!-- Dots Decor right -->
    <div class="dots-decor dots-right">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="2" cy="2" r="2" fill="#F97316"/>
        <circle cx="14" cy="2" r="2" fill="#F97316"/>
        <circle cx="26" cy="2" r="2" fill="#F97316"/>
        <circle cx="38" cy="2" r="2" fill="#F97316"/>
        <circle cx="2" cy="14" r="2" fill="#F97316"/>
        <circle cx="14" cy="14" r="2" fill="#F97316"/>
        <circle cx="26" cy="14" r="2" fill="#F97316"/>
        <circle cx="38" cy="14" r="2" fill="#F97316"/>
        <circle cx="2" cy="26" r="2" fill="#F97316"/>
        <circle cx="14" cy="26" r="2" fill="#F97316"/>
        <circle cx="26" cy="26" r="2" fill="#F97316"/>
        <circle cx="38" cy="26" r="2" fill="#F97316"/>
      </svg>
    </div>

  </div>
</section>

<style>
  .lp-comparison-section {
    padding-top: 100px;
    padding-bottom: 100px;
    background: #f8fafc; /* matching the previous section */
    position: relative;
    overflow: hidden;
  }
  
  .comp-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 60px auto;
  }
  
  .comp-title {
    font-size: 42px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--ink-900);
    margin: 0 0 16px 0;
  }
  
  .text-orange {
    color: var(--orange-600);
  }
  
  .comp-sub {
    font-size: 16.5px;
    line-height: 1.6;
    color: var(--ink-600);
    margin: 0;
  }

  .comp-table {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    background: white;
    border-radius: 20px;
    border: 1.5px solid var(--orange-100);
    box-shadow: 0 10px 40px rgba(0,0,0,0.04);
  }

  .comp-row {
    display: flex;
    position: relative;
    border-bottom: 1px dashed #e2e8f0;
  }
  .comp-row:last-child {
    border-bottom: none;
  }

  .comp-col {
    flex: 1;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    min-height: 90px;
  }

  .comp-col-left {
    background: #f8fafc; /* soft grey */
  }

  .comp-col-right {
    background: white;
    /* Soft orange outer glow for the right column wrapper is handled by pseudo element below */
  }

  /* First row radiuses */
  .comp-row:first-child .comp-col-left {
    border-top-left-radius: 20px;
  }
  .comp-row:first-child .comp-col-right {
    border-top-right-radius: 20px;
  }
  
  /* Last row radiuses */
  .comp-row:last-child .comp-col-left {
    border-bottom-left-radius: 20px;
  }
  .comp-row:last-child .comp-col-right {
    border-bottom-right-radius: 20px;
  }

  /* VS Badge */
  .vs-badge {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 36px;
    height: 36px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 800;
    color: var(--orange-600);
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    z-index: 10;
  }

  /* Header Row Styling */
  .comp-header-row {
    border-bottom: 1px solid #e2e8f0;
  }
  .comp-header-row .comp-col {
    padding: 32px 32px;
    justify-content: center;
  }
  .comp-header-row .comp-col-left {
    background: #f1f5f9; /* slightly darker grey for header */
  }
  
  .right-header-bg {
    background: #fff4ed !important; /* Soft orange bg */
  }

  .header-icon-box {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-500);
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    flex-shrink: 0;
  }
  .header-icon-box svg { width: 24px; height: 24px; }
  
  .orange-box {
    background: var(--orange-500);
    color: white;
  }

  .header-col h3 {
    font-size: 24px;
    font-weight: 800;
    margin: 0;
    color: var(--ink-900);
  }
  .comp-header-row .comp-col-right h3 {
    color: var(--orange-600);
  }

  /* Items Styling */
  .item-icon-box {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #e2e8f0; /* darker grey */
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-600);
    flex-shrink: 0;
  }
  .orange-text {
    background: var(--orange-50);
    color: var(--orange-600);
  }
  .item-icon-box svg { width: 22px; height: 22px; }

  .item-text {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--ink-800);
    margin: 0;
  }
  .comp-col-right .item-text {
    color: var(--ink-900);
    font-weight: 700;
  }

  /* Decor */
  .dots-decor {
    position: absolute;
    z-index: 1;
    opacity: 0.3;
  }
  .dots-left {
    left: 8%;
    top: 150px;
  }
  .dots-right {
    right: 8%;
    bottom: 50px;
  }

  /* Right column outer shadow to create separation */
  .comp-table::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    box-shadow: 15px 0px 50px rgba(249, 115, 22, 0.08);
    border-radius: 0 20px 20px 0;
    pointer-events: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .comp-row {
      flex-direction: column;
      border-bottom: none;
      margin-bottom: 24px;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.04);
      background: white;
      border: 1.5px solid var(--orange-100);
    }
    
    .comp-table {
      background: transparent;
      box-shadow: none;
    }
    .comp-table::after {
      display: none;
    }
    
    .comp-col {
      min-height: auto;
      padding: 24px;
    }
    .comp-header-row .comp-col {
      padding: 24px;
      justify-content: flex-start;
    }
    
    .comp-col-left, .comp-col-right {
      border-radius: 0 !important;
    }

    .vs-badge {
      width: 32px;
      height: 32px;
      font-size: 12px;
    }
    
    .comp-title {
      font-size: 32px;
    }
  }

  @media (max-width: 640px) {
    .lp-comparison-section {
      padding-top: 60px;
      padding-bottom: 60px;
    }
    .dots-decor {
      display: none; /* Hide dots on small mobile to avoid horizontal scrolling */
    }
  }
</style>
