---
import ArrowRight from '@components/icons/ArrowRight.astro';

interface Props {
  platform: 'meta' | 'google';
  heading?: string;
  sub?: string;
}
const { platform, heading = 'Ajukan Akun Whitelist', sub = 'Isi data singkat, tim kami hubungi kamu.' } = Astro.props;
const formId = `shortform-${platform}`;
---
<section aria-labelledby="shortform-heading">
  <div class="container" style="max-width:620px;">
    <h2 id="shortform-heading" class="section-title">{heading}</h2>
    <p class="section-sub" style="margin-bottom:32px;">{sub}</p>
    <form id={formId} class="shortform" data-platform={platform} novalidate>
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="sf-hp" aria-hidden="true" />
      <div class="sf-field">
        <label for={`${formId}-nama`}>Nama Lengkap</label>
        <input id={`${formId}-nama`} type="text" name="nama" placeholder="Nama Anda" required maxlength="100" />
      </div>
      <div class="sf-field">
        <label for={`${formId}-wa`}>Nomor WhatsApp</label>
        <input id={`${formId}-wa`} type="tel" name="whatsapp" placeholder="0812-xxxx-xxxx" required maxlength="20" />
      </div>
      <div class="sf-field">
        <label for={`${formId}-ket`}>Keterangan Project Singkat</label>
        <textarea id={`${formId}-ket`} name="keterangan" placeholder="Produk/jasa, target, dan kebutuhan akun..." rows="3" maxlength="500"></textarea>
      </div>
      <button type="submit" class="btn btn-primary sf-submit" style="justify-content:center;width:100%;">
        <span class="sf-btn-label">Kirim <ArrowRight size={14} /></span>
        <span class="sf-btn-loading" aria-hidden="true"><span class="sf-spinner"></span> Mengirim…</span>
      </button>
      <p class="sf-sent" role="status" aria-live="polite" hidden>Terkirim! Mengarahkan kamu ke WhatsApp…</p>
      <p class="sf-err" role="alert" aria-live="assertive" hidden></p>
    </form>
  </div>
</section>

<style>
  .shortform {
    background: white;
    border: 1px solid var(--ink-100);
    border-radius: var(--radius-xl);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sf-hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .sf-field { display: flex; flex-direction: column; gap: 6px; }
  .sf-field label { font-size: 13px; font-weight: 600; color: var(--ink-700); }
  .sf-field input, .sf-field textarea {
    font: inherit; padding: 12px 14px;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--ink-100); background: white;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .sf-field input:focus, .sf-field textarea:focus {
    outline: none; border-color: var(--orange-500);
    box-shadow: 0 0 0 3px rgba(255,107,26,0.15);
  }
  .sf-field textarea { resize: vertical; min-height: 80px; }
  .sf-sent { color: #15803d; font-size: 14px; font-weight: 600; margin: 0; }
  .sf-err { color: #b91c1c; font-size: 14px; margin: 0; }

  /* Tombol kirim: state default vs loading */
  .sf-submit { position: relative; }
  .sf-submit .sf-btn-label { display: inline-flex; align-items: center; gap: 8px; }
  .sf-submit .sf-btn-loading { display: none; align-items: center; gap: 8px; }
  .sf-submit.is-loading .sf-btn-label { display: none; }
  .sf-submit.is-loading .sf-btn-loading { display: inline-flex; }
  .sf-submit[disabled] { opacity: 0.85; cursor: progress; }
  .sf-spinner {
    width: 15px; height: 15px;
    border: 2px solid rgba(255,255,255,0.45);
    border-top-color: #fff;
    border-radius: 50%;
    display: inline-block;
    animation: sf-spin 0.6s linear infinite;
  }
  @keyframes sf-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .sf-spinner { animation-duration: 1.6s; }
  }
</style>

<script>
  // Shortform whitelist → Google Apps Script Sheet (GET fire-and-forget).
  // Ganti SHORTFORM_URL dengan URL /exec setelah deploy Apps Script (lihat docs/apps-script/SETUP.md).
  const SHORTFORM_URL = 'https://script.google.com/macros/s/AKfycbyXhHmMTM4t9xLmox8tqULrGfk3XJf28DLRbHDKIPLJF2vEpV9mHZeTE3TVMXxiuZVR/exec';
  // Nomor WA tujuan (sama dengan StickyWA / kontak). PUBLIC_WA_NUMBER di-inline saat build.
  const RAW_WA = import.meta.env.PUBLIC_WA_NUMBER ?? '6285129992225';
  const WA_NUMBER = String(RAW_WA).replace(/\D/g, '').slice(0, 15);

  const forms = document.querySelectorAll<HTMLFormElement>('form.shortform');
  const NAME_RE = /^[\p{L}\p{M}\s.\-']{2,100}$/u;
  const PHONE_RE = /^[0-9+\-\s()]{6,20}$/;
  const CTRL_RE = new RegExp('[\\u0000-\\u001F\\u007F]', 'g');
  const clip = (v: string, n: number) => v.replace(CTRL_RE, ' ').slice(0, n).trim();

  const hasEndpoint = typeof SHORTFORM_URL === 'string' && SHORTFORM_URL.indexOf('http') === 0;

  // Greeting WhatsApp disesuaikan per platform.
  function waGreeting(platform: string, nama: string, ket: string): string {
    const layanan = platform === 'google' ? 'Google Ads Whitelist'
                  : platform === 'meta'   ? 'Meta Ads Whitelist'
                  : 'Sewa Akun Whitelist';
    let msg = `Halo Tentaklik! Saya ${nama}, ingin mengajukan ${layanan}.`;
    if (ket) msg += `\n\nKebutuhan: ${ket}`;
    msg += `\n\n(Dikirim via form ${layanan})`;
    return msg;
  }

  forms.forEach((form) => {
    const sent = form.querySelector<HTMLElement>('.sf-sent');
    const err  = form.querySelector<HTMLElement>('.sf-err');
    const btn  = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const platform = form.getAttribute('data-platform') ?? '';
    const showErr = (t: string) => { if (err) { err.textContent = t; err.hidden = false; setTimeout(() => { if (err) err.hidden = true; }, 5000); } };
    let busy = false;

    const setLoading = (on: boolean) => {
      busy = on;
      if (btn) { btn.disabled = on; btn.classList.toggle('is-loading', on); }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (busy) return; // anti double-submit
      if (sent) sent.hidden = true; // reset banner state

      const fd = new FormData(form);
      if (String(fd.get('website') ?? '').length > 0) return; // honeypot
      const nama = clip(String(fd.get('nama') ?? ''), 100);
      const wa   = clip(String(fd.get('whatsapp') ?? ''), 20);
      const ket  = clip(String(fd.get('keterangan') ?? ''), 500);
      if (!NAME_RE.test(nama)) { showErr('Nama tidak valid (2–100 karakter).'); return; }
      if (!PHONE_RE.test(wa))  { showErr('Nomor WhatsApp tidak valid.'); return; }

      // Belum ada endpoint (URL masih placeholder) → jangan klaim sukses palsu.
      if (!hasEndpoint) { showErr('Form belum aktif. Hubungi kami via WhatsApp untuk sementara.'); return; }

      setLoading(true);
      const params = new URLSearchParams({
        platform: platform, nama: nama, whatsapp: wa,
        keterangan: ket, source: window.location.href,
      });

      // Simpan ke sheet (no-cors → opaque, .finally menandai request selesai), lalu arahkan ke WhatsApp.
      const waUrl = WA_NUMBER
        ? `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(waGreeting(platform, nama, ket))}`
        : '';
      fetch(SHORTFORM_URL + '?' + params.toString(), { mode: 'no-cors' })
        .catch(() => {})
        .finally(() => {
          form.reset();
          if (sent) sent.hidden = false;
          setLoading(false);
          if (waUrl) {
            // Beri jeda singkat agar user lihat status "Terkirim", lalu redirect.
            setTimeout(() => { window.location.href = waUrl; }, 800);
          }
        });
    });
  });
</script>
