---
import { getLang, useT } from '@i18n/utils';
interface Step { title: string; desc: string; }
interface Props { steps: Step[]; }
const { steps } = Astro.props;
const lang = getLang(Astro.currentLocale);
const t = useT(lang);
---
<section>
  <div class="container">
    <h2 class="section-title">{t('svc.process.title')}</h2>
    <p class="section-sub" style="margin-bottom:40px;">{t('svc.process.sub')}</p>
    <div style={`display:grid;grid-template-columns:repeat(${steps.length}, 1fr);gap:16px;`}>
      {steps.map((s, i) => (
        <div class="process-step reveal">
          <span class="process-num">{String(i + 1).padStart(2, '0')}</span>
          <h3 style="font-size:17px;margin-bottom:6px;">{s.title}</h3>
          <p style="font-size:13px;color:var(--ink-500);">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
