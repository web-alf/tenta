---
import ArrowRight from '../../icons/ArrowRight.astro';
import { getLang, useT } from '@i18n/utils';
interface Props { eyebrow: string; title: string; titleAccent: string; desc: string; ctaText?: string; }
const lang = getLang(Astro.currentLocale);
const t = useT(lang);
const { eyebrow, title, titleAccent, desc, ctaText = t('svc.hero.cta') } = Astro.props;
---
<section style="padding-top:56px;padding-bottom:56px;background:var(--bg-warm);position:relative;overflow:hidden;">
  <div class="container" style="display:grid;grid-template-columns:1.1fr 1fr;gap:40px;align-items:center;">
    <div>
      <span class="eyebrow">{eyebrow}</span>
      <h1 style="font-size:50px;margin-top:18px;margin-bottom:18px;">
        {title} <span style="color:var(--orange-500);">{titleAccent}</span>
      </h1>
      <p style="font-size:17px;color:var(--ink-500);max-width:520px;margin-bottom:28px;">{desc}</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="#pricing" class="btn btn-primary">Lihat Paket <ArrowRight size={14} /></a>
        <a href="/kontak" class="btn btn-ghost">{ctaText}</a>
      </div>
    </div>
    <div style="position:relative;display:flex;justify-content:center;align-items:center;min-height:380px;">
      <slot name="illustration" />
    </div>
  </div>
</section>
