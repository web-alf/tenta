---
import { getLang, useT } from '@i18n/utils';
import { waLink } from '@data/site';

interface Plan {
  name: string;
  tagline: string;
  price: string;
  unit: string;
  featured?: boolean;
  features: string[];
}

interface Props {
  plans: Plan[];
  service: string;
  lang?: 'en' | 'id';
}

const { plans, service, lang: propLang } = Astro.props;
const lang = propLang || getLang(Astro.currentLocale);
const t = useT(lang);
---
<section id="pricing" style="background:var(--bg-warm);scroll-margin-top:90px;">
  <div class="container">
    <h2 class="section-title">{t('svc.pricing.title')}</h2>
    <p class="section-sub" style="margin-bottom:48px;">{t('svc.pricing.sub')}</p>
    <div class="pricing-grid">
      {plans.map((p: Plan) => (
        <div class={`pricing-card reveal ${p.featured ? 'featured' : ''}`}>
          <div>
            <h3 style="font-size:20px;">{p.name}</h3>
            <p style="font-size:13px;color:var(--ink-500);margin-top:4px;">{p.tagline}</p>
          </div>
          <div class="price">{p.price}<small> {p.unit}</small></div>
          <ul class="feat-list">
            {p.features.map((f: string) => <li>{f}</li>)}
          </ul>
          <a
            href={waLink(lang === 'en'
              ? `Hi Tentaklik! I'm interested in the ${p.name} plan (${p.price} ${p.unit}) for ${service}. Could you share more details?`
              : `Halo Tentaklik! Saya tertarik dengan paket ${p.name} (${p.price}${p.unit}) untuk layanan ${service}. Bisa minta info lebih lanjut?`)}
            target="_blank"
            rel="noopener noreferrer"
            class={`btn ${p.featured ? 'btn-primary' : 'btn-ghost'}`}
            style="justify-content:center;margin-top:auto;"

          >{t('svc.pricing.btn')}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px;
    max-width: 1240px;
    margin: 0 auto;
  }
  .pricing-grid > :global(.pricing-card) {
    flex: 1 1 180px;
    max-width: 260px;
  }
  @media (max-width: 760px) {
    .pricing-grid { flex-direction: column; align-items: center; }
    .pricing-grid > :global(.pricing-card) { flex: 1 1 100%; max-width: 400px; width: 100%; }
  }
</style>
