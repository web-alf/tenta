---
import { waLink } from '@data/site';
interface Plan { name: string; tagline: string; price: string; unit: string; featured?: boolean; features: string[]; }
interface Props { plans: Plan[]; service: string; }
const { plans, service } = Astro.props;
---
<section id="pricing" style="background:var(--bg-warm);scroll-margin-top:90px;">
  <div class="container">
    <h2 class="section-title">Pilih Paket yang Sesuai</h2>
    <p class="section-sub" style="margin-bottom:48px;">Transparan, no hidden fee. Bisa custom sesuai kebutuhan.</p>
    <div class="pricing-grid">
      {plans.map(p => (
        <div class={`pricing-card reveal ${p.featured ? 'featured' : ''}`}>
          <div>
            <h3 style="font-size:20px;">{p.name}</h3>
            <p style="font-size:13px;color:var(--ink-500);margin-top:4px;">{p.tagline}</p>
          </div>
          <div class="price">{p.price}<small> {p.unit}</small></div>
          <ul class="feat-list">
            {p.features.map(f => <li>{f}</li>)}
          </ul>
          <a
            href={waLink(`Halo Tentaklik! Saya tertarik dengan paket ${p.name} (${p.price}${p.unit}) untuk layanan ${service}. Bisa minta info lebih lanjut?`)}
            target="_blank"
            rel="noopener noreferrer"
            class={`btn ${p.featured ? 'btn-primary' : 'btn-ghost'}`}
            style="justify-content:center;margin-top:auto;"
           
          >Beli Paket</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 18px;
    max-width: 1240px;
    margin: 0 auto;
  }
  @media (max-width: 760px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 400px; }
  }
</style>
