---
import ArrowRight from '../icons/ArrowRight.astro';
import Star from '../icons/Star.astro';
import { getLang, useT } from '@i18n/utils';
const lang = getLang(Astro.currentLocale);
const t = useT(lang);
const features = [
  { icon: 'target',  title: t('hero.f1.t'), sub: t('hero.f1.d') },
  { icon: 'shield',  title: t('hero.f2.t'), sub: t('hero.f2.d') },
  { icon: 'chart',   title: t('hero.f3.t'), sub: t('hero.f3.d') },
  { icon: 'headset', title: t('hero.f4.t'), sub: t('hero.f4.d') },
];
---
<section class="hero-wrap" style="padding-top:40px;padding-bottom:48px;position:relative;overflow:hidden;">
  <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;z-index:0;">
    <div style="position:absolute;top:-80px;right:-120px;width:520px;height:520px;border-radius:50%;background:radial-gradient(circle, rgba(255,122,26,0.10), rgba(255,122,26,0) 70%);"></div>
    <div style="position:absolute;bottom:-60px;left:-100px;width:360px;height:360px;border-radius:50%;background:radial-gradient(circle, rgba(255,122,26,0.06), rgba(255,122,26,0) 70%);"></div>
  </div>
  <div class="container hero-grid" style="display:grid;grid-template-columns:1.05fr 1fr;gap:48px;align-items:center;position:relative;z-index:1;">
    <div>
      <div style="display:inline-flex;align-items:center;gap:10px;padding:8px 14px;border-radius:999px;background:white;border:1px solid var(--ink-100);box-shadow:0 2px 8px rgba(31,26,23,0.04);font-size:13px;font-weight:600;color:var(--ink-700);">
        <span style="width:22px;height:22px;border-radius:6px;background:var(--orange-500);display:inline-flex;align-items:center;justify-content:center;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4z" fill="white"/><path d="M9 12l2 2 4-4" stroke="var(--orange-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        {t('hero.badge')}
      </div>
      <h1 class="hero-title" style="font-size:44px;line-height:1.15;margin-top:22px;margin-bottom:20px;letter-spacing:-0.015em;">
        {t('hero.title1')} <span style="color:var(--orange-500);">{t('hero.titleAccent')}</span><br/>
        {t('hero.title2')}
      </h1>
      <p style="font-size:16px;color:var(--ink-500);max-width:540px;margin-bottom:32px;line-height:1.65;">
        {t('hero.desc')}
      </p>
      <div style="display:flex;gap:18px;flex-wrap:wrap;margin-bottom:36px;align-items:center;">
        <a href="#final-cta" class="btn btn-wa" style="padding-inline:22px;">
          {t('hero.cta')}
          <ArrowRight size={14} />
        </a>
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="display:flex;align-items:center;gap:4px;">
            <Star size={16} /><Star size={16} /><Star size={16} /><Star size={16} /><Star size={16} />
          </div>
          <div style="display:flex;flex-direction:column;">
            <div style="font-size:15px;font-weight:700;color:var(--ink-900);line-height:1.1;">4.9 / 5</div>
            <div style="font-size:12.5px;color:var(--ink-500);margin-top:2px;">{t('hero.proof')}</div>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-mascot-wrap" id="hero-kraken-wrap" style="position:relative;min-height:480px;display:flex;align-items:center;justify-content:center;">
      <div class="kraken-float" style="width:100%;max-width:560px;">
        <picture>
          <source
            type="image/avif"
            srcset="/assets/kraken-hero-400.avif 400w, /assets/kraken-hero-560.avif 560w, /assets/kraken-hero-800.avif 800w, /assets/kraken-hero.avif 1200w"
            sizes="(max-width: 760px) min(480px, 95vw), 560px"
          />
          <source
            type="image/webp"
            srcset="/assets/kraken-hero-400.webp 400w, /assets/kraken-hero-560.webp 560w, /assets/kraken-hero-800.webp 800w, /assets/kraken-hero.webp 1200w"
            sizes="(max-width: 760px) min(480px, 95vw), 560px"
          />
          <img
            src="/assets/kraken-hero.png"
            alt="Tentaklik kraken mascot"
            width="1200"
            height="960"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </picture>
      </div>
    </div>
  </div>
  <div class="container" style="margin-top:48px;position:relative;z-index:1;">
    <div class="hero-feature-strip">
      {features.map(f => (
        <div class="hero-feature-cell">
          <div class="hero-feature-icon">
            {f.icon === 'target' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>}
            {f.icon === 'shield' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l8 3v6c0 4.5-3.3 8.5-8 9.5C7.3 20.5 4 16.5 4 12V6l8-3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>}
            {f.icon === 'chart' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 20V11M12 20V4M19 20v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>}
            {f.icon === 'headset' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 14v-2a8 8 0 0116 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><rect x="3" y="13" width="4" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><rect x="17" y="13" width="4" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8"/><path d="M21 19c0 1.5-1.5 3-4 3h-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>}
          </div>
          <div>
            <div style="font-size:14px;font-weight:700;color:var(--ink-900);margin-bottom:4px;">{f.title}</div>
            <div style="font-size:12.5px;color:var(--ink-500);line-height:1.45;">{f.sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-feature-cell { display:flex; align-items:center; gap:14px; padding:16px; }
  .hero-feature-icon { width:44px; height:44px; border-radius:12px; background:var(--orange-50); color:var(--orange-700); display:flex; align-items:center; justify-content:center; flex-shrink:0; }

  /* Float animation untuk kraken */
  @keyframes krakenFloat {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    25%       { transform: translateY(-14px) rotate(0.8deg); }
    75%       { transform: translateY(-6px) rotate(-0.5deg); }
  }
  .kraken-float {
    animation: krakenFloat 4.5s ease-in-out infinite;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 28px 56px rgba(255, 107, 26, 0.22));
    will-change: transform;
  }
  .kraken-float :global(picture) { display: block; width: 100%; }
  .kraken-float :global(img) { width: 100%; height: auto; display: block; }
  @media (prefers-reduced-motion: reduce) {
    .kraken-float { animation: none; }
  }
</style>

