---
import { getLang, useT } from '@i18n/utils';
import TentaklikLogo from '../brand/TentaklikLogo.astro';
import YouTube from '../icons/YouTube.astro';
import Instagram from '../icons/Instagram.astro';
import TikTok from '../icons/TikTok.astro';
import WhatsApp from '../icons/WhatsApp.astro';
import Email from '../icons/Email.astro';
import Pin from '../icons/Pin.astro';
import { site, waLink } from '@data/site';

interface Props {
  lang?: 'en' | 'id';
}
const { lang: propLang } = Astro.props;
const lang = propLang || getLang(Astro.currentLocale);
const t = useT(lang);
const L = (p: string) => (lang === 'en' ? '/en' + (p === '/' ? '' : p) : p) || '/';
---
<footer class="footer">
  <div class="container footer-grid">
    <div>
      <div style="margin-bottom:14px;"><TentaklikLogo size={24} variant="white" /></div>
      <p style="font-size:14px;color:var(--ink-300);max-width:280px;line-height:1.6;">{t('footer.tagline')}</p>
      <div style="display:flex;gap:12px;margin-top:18px;">
        <a href={site.social.youtube} aria-label="YouTube" target="_blank" rel="noopener noreferrer" style="width:36px;height:36px;border-radius:999px;background:rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;"><YouTube size={16} /></a>
        <a href={site.social.instagram} aria-label="Instagram" target="_blank" rel="noopener noreferrer" style="width:36px;height:36px;border-radius:999px;background:rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;"><Instagram size={16} /></a>
        <a href={site.social.tiktok} aria-label="TikTok" target="_blank" rel="noopener noreferrer" style="width:36px;height:36px;border-radius:999px;background:rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;"><TikTok size={16} /></a>
      </div>
    </div>
    <div>
      <h4>{t('footer.layanan')}</h4>
      <ul>
        <li><a href={L("/layanan/website")}>{t('svc.website')}</a></li>
        <li>
          <a href={L("/layanan/sewa-akun")}>{t('svc.sewaAkun')}</a>
          <ul class="footer-subnav">
            <li><a href={L("/meta-whitelist")}>{t('footer.metaWhitelist')}</a></li>
            <li><a href={L("/google-whitelist")}>{t('footer.googleWhitelist')}</a></li>
          </ul>
        </li>
        <li><a href={L("/layanan/konsultasi")}>{t('svc.konsultasi')}</a></li>
      </ul>
    </div>
    <div>
      <h4>{t('footer.halaman')}</h4>
      <ul>
        <li><a href={L("/")}>{t('nav.beranda')}</a></li>
        <li><a href={L("/tentang")}>{t('footer.tentang')}</a></li>
        <li><a href={L("/partner")}>{t('footer.partner')}</a></li>
        <li><a href={L("/#faq")}>{t('footer.faq')}</a></li>
        <li><a href="https://mediawaktu.com" target="_blank" rel="noopener noreferrer">{t('nav.blog')} ↗</a></li>
      </ul>
    </div>
    <div>
      <h4>{t('footer.kontak')}</h4>
      <ul>
        <li style="display:flex;align-items:center;gap:8px;"><WhatsApp size={14} /> <a href={waLink('Halo Tentaklik! Saya ingin menanyakan lebih lanjut mengenai layanan digital marketing Anda. Bisa bantu saya?')} target="_blank" rel="noopener noreferrer" class="footer-wa-link">{site.phone}</a></li>
        <li style="display:flex;align-items:center;gap:8px;"><Email size={14} /> {site.email}</li>
        <li style="display:flex;align-items:center;gap:8px;"><Pin size={14} /> {site.address}</li>
      </ul>
    </div>
  </div>
  <div class="container partner-row" style="margin-top:40px;padding-top:24px;border-top:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
    <span style="font-size:12px;color:var(--ink-300);font-weight:600;letter-spacing:0.06em;text-transform:uppercase;">{t('footer.officialPartner')}</span>
    <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;">
      <a href="https://www.google.com/partners/agency?id=1004085415" target="_blank" rel="noopener noreferrer" aria-label="Google Partner" class="partner-logo">
        <picture><source type="image/avif" srcset="/assets/partner-google.avif" /><source type="image/webp" srcset="/assets/partner-google.webp" /><img src="/assets/partner-google.png" alt="Google Partner" width="140" height="64" loading="lazy" decoding="async" /></picture>
      </a>
      <a href="https://www.facebook.com/business/partner-directory" target="_blank" rel="noopener noreferrer" aria-label="Meta Business Partner" class="partner-logo">
        <img src="/assets/partner-meta.png" alt="Meta Business Partner" width="140" height="64" loading="lazy" decoding="async" />
      </a>
    </div>
  </div>
  <div class="container footer-legal" style="margin-top:24px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.06);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;font-size:13px;color:var(--ink-300);">
    <span>© {new Date().getFullYear()} Tentaklik. {t('footer.rights')} {t('footer.managedBy')} <strong style="color:var(--ink-100);font-weight:600;">{site.legalEntity}</strong>.</span>
    <div style="display:flex;gap:18px;flex-wrap:wrap;">
      <a href={L("/ketentuan")} class="footer-legal-link">{t('footer.terms')}</a>
      <a href={L("/disclaimer")} class="footer-legal-link">{t('footer.disclaimer')}</a>
    </div>
  </div>
</footer>

<style>
  .footer-subnav { list-style: none; padding: 6px 0 0 14px; margin: 6px 0 0; display: flex; flex-direction: column; gap: 8px; border-left: 1px solid rgba(255,255,255,0.12); }
  .footer-subnav li::before { content: "› "; color: var(--ink-300); }
  .footer-legal-link {
    color: var(--ink-300);
    transition: color 0.15s;
  }
  .footer-legal-link:hover {
    color: var(--orange-300);
  }
  .footer-wa-link {
    color: inherit;
    transition: color 0.15s;
  }
  .footer-wa-link:hover,
  .footer-wa-link:focus-visible {
    color: var(--orange-300);
  }
</style>
