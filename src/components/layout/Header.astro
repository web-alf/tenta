---
import TentaklikLogo from '../brand/TentaklikLogo.astro';
import ServiceIcon from '../icons/ServiceIcon.astro';
import { getLang, useT, stripLocale } from '@i18n/utils';

interface Props {
  active?: 'beranda' | 'layanan' | 'case' | 'tentang' | 'karir' | 'snk' | 'faq' | 'kontak';
  lang?: 'en' | 'id';
}
const { active = 'beranda', lang: propLang } = Astro.props;

const lang = propLang || getLang(Astro.currentLocale);
const t = useT(lang);
// Localize internal path untuk bahasa aktif (EN → prefix /en).
const L = (path: string) => (lang === 'en' ? `/en${path === '/' ? '' : path}` : path) || '/';
// Path netral (tanpa /en) untuk language switcher.
const basePath = stripLocale(Astro.url.pathname);

const services = [
  { label: t('svc.website'),    href: L('/layanan/website'),    icon: 'code' as const },
  { label: t('svc.sewaAkun'),   href: L('/layanan/sewa-akun'),  icon: 'shield' as const },
  { label: t('svc.konsultasi'), href: L('/layanan/konsultasi'), icon: 'lightbulb' as const },
];

// Link sebelum dropdown Layanan
const linksBefore = [
  { id: 'tentang', label: t('nav.tentang'), href: L('/tentang') },
];
// Link setelah dropdown Layanan
const linksAfter = [
  { id: 'case', label: t('nav.partner'), href: L('/partner') },
  { id: 'faq',  label: t('nav.faq'),     href: L('/#faq') },
];
const blogHref = 'https://mediawaktu.com';
const homeHref = L('/');
const kontakHref = L('/kontak');

// Language switcher: link ke path yang sama di bahasa lain.
const langOptions = [
  { code: 'id', label: t('nav.lang.id'), href: basePath === '/' ? '/' : basePath },
  { code: 'en', label: t('nav.lang.en'), href: basePath === '/' ? '/en' : `/en${basePath}` },
] as const;
---
<header class="header" id="site-header">
  <div class="container nav">
    <a href="/" style="display:flex;align-items:center;flex-shrink:0;" aria-label="Tentaklik beranda">
      <TentaklikLogo size={22} />
    </a>

    <!-- Desktop nav — hidden on mobile via CSS -->
    <nav class="nav-links nav-desktop" aria-label="Navigasi utama">
      <a href={homeHref} class={active === 'beranda' ? 'active' : ''}>{t('nav.beranda')}</a>

      {linksBefore.map(l => (
        <a href={l.href} class={active === l.id ? 'active' : ''}>{l.label}</a>
      ))}

      <!-- Layanan dropdown -->
      <div class="nav-dropdown-wrap" id="layanan-wrap">
        <button
          class={`nav-dropdown-trigger ${active === 'layanan' ? 'active' : ''}`}
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="layanan-menu"
          type="button"
        >
          {t('nav.layanan')}
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="nav-dropdown" id="layanan-menu" role="menu">
          {services.map(s => (
            <a href={s.href} class="nav-dropdown-item" role="menuitem">
              <span class="nav-dropdown-icon" aria-hidden="true"><ServiceIcon type={s.icon} size={16} /></span>
              {s.label}
            </a>
          ))}
        </div>
      </div>

      {linksAfter.map(l => (
        <a href={l.href} class={active === l.id ? 'active' : ''}>{l.label}</a>
      ))}

      <a href={blogHref} target="_blank" rel="noopener noreferrer" class="nav-blog-link">{t('nav.blog')} <span aria-hidden="true">↗</span></a>

      <!-- Language switcher -->
      <div class="nav-dropdown-wrap nav-lang-wrap" id="lang-wrap">
        <button
          class="nav-dropdown-trigger nav-lang-trigger"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="lang-menu"
          aria-label={t('nav.lang')}
          type="button"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span class="nav-lang-code">{lang.toUpperCase()}</span>
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="nav-dropdown nav-lang-menu" id="lang-menu" role="menu">
          {langOptions.map(o => (
            <a href={o.href} class={`nav-dropdown-item ${o.code === lang ? 'active' : ''}`} role="menuitem" hreflang={o.code}>
              <span class="nav-lang-badge" aria-hidden="true">{o.code.toUpperCase()}</span>
              {o.label}
            </a>
          ))}
        </div>
      </div>

      <a href={kontakHref} class="btn btn-primary nav-kontak-btn">{t('nav.kontak')}</a>
    </nav>

    <!-- Burger (mobile only) -->
    <button
      class="nav-burger"
      id="nav-burger"
      aria-label="Buka menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      type="button"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile drawer — OUTSIDE header, fixed to viewport -->
<div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-modal="true" aria-label="Menu navigasi" aria-hidden="true">
  <div class="mobile-drawer-panel" id="mobile-drawer-panel">
    <!-- Close button di dalam panel -->
    <button class="drawer-close" id="drawer-close" type="button" aria-label="Tutup menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <nav class="mobile-drawer-links" aria-label="Navigasi mobile">
      <a href={homeHref} class={active === 'beranda' ? 'active' : ''}>{t('nav.beranda')}</a>

      {linksBefore.map(l => (
        <a href={l.href} class={active === l.id ? 'active' : ''}>{l.label}</a>
      ))}

      <!-- Layanan accordion -->
      <div class="mobile-layanan">
        <button class="mobile-layanan-trigger" type="button" aria-expanded="false">
          {t('nav.layanan')}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="mobile-layanan-sub" hidden>
          {services.map(s => (
            <a href={s.href} class="mobile-sub-item">
              <span aria-hidden="true" style="display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;color:var(--orange-700);"><ServiceIcon type={s.icon} size={18} /></span> {s.label}
            </a>
          ))}
        </div>
      </div>

      {linksAfter.map(l => (
        <a href={l.href} class={active === l.id ? 'active' : ''}>{l.label}</a>
      ))}

      <a href={blogHref} target="_blank" rel="noopener noreferrer">{t('nav.blog')} ↗</a>

      <!-- Language switcher (mobile) -->
      <div class="mobile-lang" role="group" aria-label={t('nav.lang')}>
        {langOptions.map(o => (
          <a href={o.href} class={`mobile-lang-item ${o.code === lang ? 'active' : ''}`} hreflang={o.code}>
            <span class="nav-lang-badge" aria-hidden="true">{o.code.toUpperCase()}</span> {o.label}
          </a>
        ))}
      </div>

      <a href={kontakHref} class="btn btn-primary mobile-kontak-btn" style="justify-content:center;margin-top:8px;">{t('nav.kontak')}</a>
    </nav>

  </div>
</div>

<style>
  /* ─── Desktop nav: hidden on mobile, visible on desktop ─── */
  .nav-desktop {
    display: none; /* default hidden */
    margin-left: auto;
  }
  @media (min-width: 1101px) {
    .nav-desktop { display: flex; }
    .nav-burger  { display: none !important; }
  }

  /* Burger visible on mobile */
  .nav-burger {
    display: flex;
    margin-left: auto; /* push to right when nav-desktop is hidden */
  }

  /* ─── Desktop dropdown ─── */
  .nav-dropdown-wrap { position: relative; }

  .nav-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    padding: 6px 0;
    font: inherit;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-700);
    cursor: pointer;
    position: relative;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .nav-dropdown-trigger:hover,
  .nav-dropdown-trigger.active { color: var(--orange-600); }
  .nav-dropdown-trigger.active::after {
    content: "";
    position: absolute;
    left: 50%; bottom: -2px;
    transform: translateX(-50%);
    width: 18px; height: 2px;
    border-radius: 2px;
    background: var(--orange-500);
  }
  .chevron { transition: transform 0.2s ease; }
  .nav-dropdown-trigger[aria-expanded="true"] .chevron { transform: rotate(180deg); }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 240px;
    background: white;
    border: 1px solid var(--ink-100);
    border-radius: var(--radius-lg);
    box-shadow: 0 12px 32px rgba(31,26,23,0.10), 0 2px 8px rgba(31,26,23,0.06);
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 200;
    /* Animasi buka/tutup: opacity + translate (individual transform,
       tak bentrok dgn transform: translateX(-50%) untuk centering). */
    opacity: 0;
    visibility: hidden;
    translate: 0 -6px;
    transition: opacity 0.18s ease, translate 0.18s ease, visibility 0.18s;
  }
  .nav-dropdown.open {
    opacity: 1;
    visibility: visible;
    translate: 0 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-dropdown { transition: none; translate: 0 0; }
  }
  .nav-dropdown::before {
    content: "";
    position: absolute;
    top: -6px; left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px; height: 12px;
    background: white;
    border-left: 1px solid var(--ink-100);
    border-top: 1px solid var(--ink-100);
  }
  .nav-dropdown-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    font-size: 14px; font-weight: 500;
    color: var(--ink-700);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .nav-dropdown-item:hover { background: var(--orange-50); color: var(--orange-700); }
  .nav-dropdown-icon {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    background: var(--orange-100);
    color: var(--orange-700);
    border-radius: 8px;
    flex-shrink: 0;
  }

  /* ─── Mobile drawer ─── */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 9999; /* above everything */
    background: rgba(14, 27, 42, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s;
  }
  .mobile-drawer.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-drawer-panel {
    position: absolute;
    top: 0; right: 0;
    width: min(320px, 88vw);
    height: 100%;
    height: 100dvh; /* dynamic viewport height — handles iOS URL bar */
    background: white;
    padding: 20px 20px 32px;
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 40px rgba(0,0,0,0.2);
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    will-change: transform;
  }
  .mobile-drawer.open .mobile-drawer-panel {
    transform: translateX(0);
  }

  /* Close button */
  .drawer-close {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink-700);
    padding: 8px;
    margin: 0 -8px 12px auto;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .drawer-close:hover { background: var(--ink-50); }

  /* Mobile links */
  .mobile-drawer-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .mobile-drawer-links > a {
    padding: 14px 12px;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink-700);
    border-radius: 10px;
    transition: background 0.15s, color 0.15s;
    display: block;
  }
  .mobile-drawer-links > a:hover,
  .mobile-drawer-links > a.active {
    background: var(--orange-50);
    color: var(--orange-600);
  }

  /* Mobile Layanan accordion */
  .mobile-layanan { display: flex; flex-direction: column; }
  .mobile-layanan-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 12px;
    font: inherit;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink-700);
    background: none;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, color 0.15s;
  }
  .mobile-layanan-trigger:hover { background: var(--orange-50); color: var(--orange-600); }
  .mobile-layanan-trigger svg { transition: transform 0.2s; flex-shrink: 0; }
  .mobile-layanan-trigger[aria-expanded="true"] svg { transform: rotate(180deg); }
  .mobile-layanan-trigger[aria-expanded="true"] { background: var(--orange-50); color: var(--orange-600); }

  .mobile-layanan-sub {
    display: flex;
    flex-direction: column;
    padding-left: 12px;
    padding-bottom: 4px;
  }
  .mobile-sub-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 12px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--ink-500);
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
  }
  .mobile-sub-item:hover { background: var(--orange-50); color: var(--orange-700); }

  /* Sejajarkan semua item nav (teks, Blog, tombol) di satu garis vertikal */
  .nav-desktop { align-items: center; }
  .nav-blog-link { display: inline-flex; align-items: center; gap: 3px; padding: 6px 0; }
  .nav-kontak-btn { padding: 9px 18px; font-size: 14px; }
  .nav-kontak-btn:hover { color: white; }

  /* Language switcher (desktop) */
  .nav-lang-trigger { gap: 5px; }
  .nav-lang-code { font-weight: 600; letter-spacing: 0.02em; }
  .nav-lang-menu { min-width: 168px; left: auto; right: 0; transform: none; }
  .nav-lang-menu::before { left: auto; right: 18px; transform: rotate(45deg); }
  .nav-lang-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 26px; height: 20px; padding: 0 6px;
    border-radius: 6px; background: var(--orange-100); color: var(--orange-700);
    font-size: 11px; font-weight: 700; letter-spacing: 0.03em;
  }
  .nav-dropdown-item.active { background: var(--orange-50); color: var(--orange-700); }
  .nav-dropdown-item.active .nav-lang-badge { background: var(--orange-500); color: #fff; }

  /* Language switcher (mobile) */
  .mobile-lang { display: flex; gap: 8px; margin: 8px 0 2px; }
  .mobile-lang-item {
    flex: 1; display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 14px; border-radius: 10px;
    font-size: 14.5px; font-weight: 600; color: var(--ink-700);
    border: 1px solid var(--ink-100);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .mobile-lang-item.active { background: var(--orange-50); color: var(--orange-700); border-color: var(--orange-200); }
  /* Tombol Kontak tetap solid oranye walau di halaman /kontak (tak ikut style .active nav teks) */
  .nav-kontak-btn.active, .nav-kontak-btn.active::after { color: white; background: var(--orange-500); }
  .nav-kontak-btn.active::after { display: none; }
</style>

<script>
  /* ── Scroll-aware header ── */
  const header = document.getElementById('site-header');
  function onScroll() {
    if (!header) return;
    header.classList.toggle('scrolled', window.scrollY > 8);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ── Desktop dropdowns (Layanan + Bahasa) ── */
  function wireDropdown(menuId: string) {
    const menu = document.getElementById(menuId);
    const wrap = menu?.closest('.nav-dropdown-wrap');
    const trigger = wrap?.querySelector<HTMLButtonElement>('.nav-dropdown-trigger');
    if (!menu || !wrap || !trigger) return;
    let closeTimer: ReturnType<typeof setTimeout> | null = null;
    const open = () => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      menu.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
    };
    const close = (immediate = false) => {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      const doClose = () => { menu.classList.remove('open'); trigger.setAttribute('aria-expanded', 'false'); };
      if (immediate) doClose();
      else closeTimer = setTimeout(() => { closeTimer = null; doClose(); }, 200);
    };
    wrap.addEventListener('mouseenter', open);
    wrap.addEventListener('mouseleave', () => close(false));
    trigger.addEventListener('click', () => menu.classList.contains('open') ? close(true) : open());
    document.addEventListener('click', e => { if (!wrap.contains(e.target as Node)) close(true); });
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => close(true)));
  }
  wireDropdown('layanan-menu');
  wireDropdown('lang-menu');

  /* ── Mobile drawer ── */
  const burger  = document.getElementById('nav-burger');
  const drawer  = document.getElementById('mobile-drawer');
  const closeBtn = document.getElementById('drawer-close');
  let lastFocused: HTMLElement | null = null;
  let savedScrollY = 0;

  function lockScroll() {
    savedScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top      = `-${savedScrollY}px`;
    document.body.style.width    = '100%';
    document.body.style.overflowY = 'scroll'; /* keep scrollbar width */
  }
  function unlockScroll() {
    document.body.style.position  = '';
    document.body.style.top       = '';
    document.body.style.width     = '';
    document.body.style.overflowY = '';
    window.scrollTo({ top: savedScrollY, behavior: 'instant' });
  }

  function openDrawer() {
    if (!burger || !drawer) return;
    lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    lockScroll();
    drawer.classList.add('open');
    drawer.setAttribute('aria-hidden', 'false');
    burger.classList.add('open');
    burger.setAttribute('aria-expanded', 'true');
    burger.setAttribute('aria-label', 'Tutup menu');
    // Focus first focusable element in drawer
    requestAnimationFrame(() => {
      const first = drawer.querySelector<HTMLElement>('button, a[href]');
      first?.focus();
    });
  }

  function closeDrawer() {
    if (!burger || !drawer) return;
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden', 'true');
    burger.classList.remove('open');
    burger.setAttribute('aria-expanded', 'false');
    burger.setAttribute('aria-label', 'Buka menu');
    unlockScroll();
    lastFocused?.focus();
  }

  burger?.addEventListener('click', () => {
    drawer?.classList.contains('open') ? closeDrawer() : openDrawer();
  });
  closeBtn?.addEventListener('click', closeDrawer);

  // Backdrop click
  drawer?.addEventListener('click', e => { if (e.target === drawer) closeDrawer(); });

  // Close on nav link click
  drawer?.querySelectorAll('a[href]').forEach(a => a.addEventListener('click', closeDrawer));

  /* Mobile Layanan accordion */
  const mobTrigger = document.querySelector<HTMLButtonElement>('.mobile-layanan-trigger');
  const mobSub     = document.querySelector<HTMLElement>('.mobile-layanan-sub');
  mobTrigger?.addEventListener('click', () => {
    const isOpen = mobTrigger.getAttribute('aria-expanded') === 'true';
    mobTrigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    if (mobSub) mobSub.hidden = isOpen;
  });

  /* Focus trap + Escape */
  function onKeydown(e: KeyboardEvent) {
    if (!drawer?.classList.contains('open')) return;
    if (e.key === 'Escape') { closeDrawer(); return; }
    if (e.key === 'Tab') {
      const focusable = drawer.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      );
      if (!focusable.length) return;
      const first = focusable[0], last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }
  document.addEventListener('keydown', onKeydown);

  /* Cleanup on page transition */
  document.addEventListener('astro:before-swap', () => {
    window.removeEventListener('scroll', onScroll);
    document.removeEventListener('keydown', onKeydown);
    if (drawer?.classList.contains('open')) unlockScroll();
  }, { once: true });
</script>
